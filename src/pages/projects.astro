---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import EmptyState from "../components/EmptyState.astro";
import Badge from "../components/Badge.astro";
import { PROJECTS } from "../data/projects";

const base = import.meta.env.BASE_URL;

const allTags = Array.from(new Set(PROJECTS.flatMap(p => p.tags))).sort();
---

<Layout title="Projects - SE31 Hub" description="Showcase of SE31 student projects.">
  <Navbar />
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold text-center mb-8">Cohort Projects</h1>

    <div class="bg-indigo-100 dark:bg-indigo-900 border-l-4 border-indigo-500 text-indigo-700 dark:text-indigo-300 p-4 mb-8" role="alert">
      <p class="font-bold">Showcase Your Work:</p>
      <p>Have you built something cool? Add your project to the showcase! <a href={`${base}contribute`} class="font-bold underline hover:text-indigo-900">Learn how to contribute.</a></p>
    </div>

    {PROJECTS.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {PROJECTS.map(project => (
          <ProjectCard project={project} />
        ))}
      </div>
    ) : (
      <EmptyState message="No projects added yet. Be the first to showcase your work!" />
    )}
  </main>
  <Footer />
</Layout>
