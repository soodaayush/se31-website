---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ProjectCard from "../components/ProjectCard.astro";
import EmptyState from "../components/EmptyState.astro";
import PageIntro from "../components/PageIntro.astro";
import { PROJECTS } from "../data/projects";

const base = import.meta.env.BASE_URL;

---

<Layout title="Projects — SE31 Nest" description="A showcase of projects made by the SE31 cohort.">
  <Navbar />
  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Made by the cohort"
      title="Cohort projects."
      description="A growing showcase of the things SE31 students are designing, coding and learning to ship."
    />

    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
      <div class="mb-10 rounded-[1.125rem] border-2 border-[#48301f]/30 border-l-[6px] border-l-[#f8cb10] bg-[#f8cb10]/20 p-5 text-[#48301f] shadow-[4px_4px_0_rgb(72_48_31_/_0.1)] dark:border-[#735a47] dark:border-l-[#f8cb10] dark:bg-[#302219] dark:text-[#fffefb]">
        <p class="font-black">Showcase your work</p>
        <p class="mt-1 leading-7">Have you built something cool? Add your project to the showcase. <a href={`${base}contribute`} class="brand-text-link font-black text-brown dark:text-hardhat">Learn how to contribute.</a></p>
      </div>

      {PROJECTS.length > 0 ? (
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {PROJECTS.map(project => (
            <ProjectCard project={project} />
          ))}
        </div>
      ) : (
        <EmptyState message="No projects added yet. Be the first to showcase your work!" />
      )}
    </div>
  </main>
  <Footer />
</Layout>
