---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageIntro from "../components/PageIntro.astro";
import { SITE_CONFIG } from "../data/siteConfig";
---

<Layout title="Contribute — SE31 Nest" description="How to contribute to the SE31 Nest website.">
  <Navbar />
  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Open source · SE31"
      title="Make this place yours."
      description="This is our shared cohort home. Improve a source, fix a rough edge or add something everyone will genuinely use."
    />

    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">

    <section class="mb-8">
      <p class="mb-4 text-lg leading-8 text-muted dark:text-[#d9d2ca]">
        SE31 Nest is an open-source project made by students, for students. Contributions from anyone in the SE31 cohort are welcome.
        Your help keeps this site useful for everyone.
      </p>
      <p class="text-lg leading-8 text-muted dark:text-[#d9d2ca]">
        Contributing is a great way to practice your web development skills, learn new technologies, and give back to your community.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-3xl font-black tracking-[-0.035em] text-ink dark:text-paper">What to improve</h2>
      <ul class="list-disc space-y-2 pl-5 text-muted marker:text-signal dark:text-[#d9d2ca] dark:marker:text-hardhat">
        <li><strong>Add a verified resource:</strong> Share useful links to academic tools, student life guides, or dev resources.</li>
        <li><strong>Add or correct a public deadline:</strong> Help keep the cohort informed about important dates.</li>
        <li><strong>Improve a course guide:</strong> Make an archived outline easier to understand without changing its meaning.</li>
        <li><strong>Improve design or accessibility:</strong> Enhance the site's look, feel, and usability.</li>
        <li><strong>Fix bugs:</strong> Help us address any issues you find.</li>
        <li><strong>Suggest new features:</strong> Propose ideas that would make our cohort home more useful.</li>
      </ul>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-3xl font-black tracking-[-0.035em] text-ink dark:text-paper">Run it locally</h2>
      <p class="mb-4 text-muted dark:text-[#d9d2ca]">
        Get the site running on your local machine to make changes:
      </p>
      <ol class="brand-card list-decimal space-y-4 p-5 pl-10 text-muted marker:font-black marker:text-signal dark:text-[#d9d2ca] dark:marker:text-hardhat">
        <li><strong>Clone the repository:</strong>
          <pre class="mt-2 overflow-x-auto rounded-lg bg-ink p-3 text-sm text-paper"><code>git clone {SITE_CONFIG.githubUrl}.git</code></pre>
        </li>
        <li><strong>Navigate into the directory:</strong>
          <pre class="mt-2 overflow-x-auto rounded-lg bg-ink p-3 text-sm text-paper"><code>cd se31-website</code></pre>
        </li>
        <li><strong>Install dependencies:</strong>
          <pre class="mt-2 overflow-x-auto rounded-lg bg-ink p-3 text-sm text-paper"><code>npm install</code></pre>
        </li>
        <li><strong>Run the development server:</strong>
          <pre class="mt-2 overflow-x-auto rounded-lg bg-ink p-3 text-sm text-paper"><code>npm run dev</code></pre>
          <p class="mt-2 text-sm">The site will be available at <a href="http://localhost:4321" target="_blank" rel="noopener noreferrer" class="brand-text-link font-bold text-spruce dark:text-lime">http://localhost:4321</a></p>
        </li>
        <li><strong>Build for production (optional):</strong>
          <pre class="mt-2 overflow-x-auto rounded-lg bg-ink p-3 text-sm text-paper"><code>npm run build</code></pre>
        </li>
      </ol>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-3xl font-black tracking-[-0.035em] text-ink dark:text-paper">Where the content lives</h2>
      <p class="mb-4 text-muted dark:text-[#d9d2ca]">
        Much of the site's content is managed through simple TypeScript data files. You can update these directly:
      </p>
      <ul class="list-disc space-y-2 pl-5 text-muted marker:text-signal dark:text-[#d9d2ca] dark:marker:text-hardhat">
        <li><code>src/data/deadlines.ts</code>: To add or update important dates.</li>
        <li><code>src/data/resources.ts</code>: For adding new helpful links.</li>
        <li><code>src/data/courses.ts</code>: To correct or expand archived course guides.</li>
        <li><code>src/data/timetable.ts</code>: To update the clearly labelled reference timetable.</li>
      </ul>
      <p class="mt-4 text-muted dark:text-[#d9d2ca]">
        Please follow the existing data structure and TypeScript types when adding new entries.
      </p>
    </section>

    <section class="mb-8">
      <h2 class="mb-4 text-3xl font-black tracking-[-0.035em] text-ink dark:text-paper">Start contributing</h2>
      <div class="flex flex-wrap gap-4">
        <a href={SITE_CONFIG.githubUrl} target="_blank" rel="noopener noreferrer" class="brand-button-primary">
          View Repository
        </a>
        <a href={`${SITE_CONFIG.githubUrl}/issues/new/choose`} target="_blank" rel="noopener noreferrer" class="brand-button-secondary">
          Open an Issue
        </a>
        <a href={`${SITE_CONFIG.githubUrl}/compare`} target="_blank" rel="noopener noreferrer" class="brand-button-highlight">
          Submit a Pull Request
        </a>
      </div>
    </section>

    <section class="mb-8 rounded-2xl border-2 border-brown bg-hardhat/30 p-6 text-ink dark:border-hardhat/60 dark:bg-hardhat/10 dark:text-paper">
      <h2 class="mb-4 text-2xl font-black">Contribution policy</h2>
      <ul class="list-disc space-y-2 pl-5 marker:text-spruce dark:marker:text-lime">
        <li>Do not submit private personal information.</li>
        <li>Do not submit unofficial deadlines without a verifiable source.</li>
        <li>Do not upload copyrighted course material or sensitive academic content.</li>
        <li>Be respectful and constructive in all interactions and contributions.</li>
      </ul>
    </section>
    </div>
  </main>
  <Footer />
</Layout>
