---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageIntro from "../components/PageIntro.astro";
import { SITE_CONFIG } from "../data/siteConfig";
---

<Layout title="Contribute — SE31 Nest" description="How to contribute to the SE31 Nest website.">
  <Navbar />
  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Open source · SE31"
      title="Make this place yours."
      description="Improve a source, fix a rough edge or add something everyone will genuinely use."
    />

    <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
      <section class="mb-12">
        <p class="text-lg leading-8 text-muted dark:text-paper/75">
          SE31 Nest is made by students, for students. Contributions from anyone in the cohort are welcome, whether that means correcting one date or building something new.
        </p>
      </section>

      <section class="mb-12">
        <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">What would help</h2>
        <ul class="divide-y divide-teal-deep/10 border-y border-teal-deep/10 dark:divide-sky/15 dark:border-sky/15">
          <li class="py-4 text-muted dark:text-paper/75"><strong class="text-ink dark:text-paper">Verify a resource:</strong> Share useful links to academic tools, student life guides or developer resources.</li>
          <li class="py-4 text-muted dark:text-paper/75"><strong class="text-ink dark:text-paper">Correct a public date:</strong> Keep the cohort informed with a reliable source.</li>
          <li class="py-4 text-muted dark:text-paper/75"><strong class="text-ink dark:text-paper">Improve a course guide:</strong> Make an archived outline easier to understand without changing its meaning.</li>
          <li class="py-4 text-muted dark:text-paper/75"><strong class="text-ink dark:text-paper">Polish the experience:</strong> Improve accessibility, design, performance or a rough interaction.</li>
        </ul>
      </section>

      <section class="mb-12">
        <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">Start contributing</h2>
        <div class="flex flex-wrap items-center gap-x-5 gap-y-3">
          <a href={SITE_CONFIG.githubUrl} target="_blank" rel="noopener noreferrer" class="brand-button-highlight">View the repository</a>
          <a href={`${SITE_CONFIG.githubUrl}/issues/new/choose`} target="_blank" rel="noopener noreferrer" class="brand-text-link font-bold text-teal-deep dark:text-sky">Open an issue ↗</a>
          <a href={`${SITE_CONFIG.githubUrl}/compare`} target="_blank" rel="noopener noreferrer" class="brand-text-link font-bold text-teal-deep dark:text-sky">Submit a pull request ↗</a>
        </div>
      </section>

      <details class="cozy-panel group mb-12 overflow-hidden">
        <summary class="cursor-pointer list-none p-6 font-display text-xl font-semibold text-ink marker:hidden dark:text-paper sm:p-7">
          Want to edit the code? <span class="ml-2 inline-block text-teal-deep transition-transform group-open:rotate-90 dark:text-sky" aria-hidden="true">→</span>
        </summary>
        <div class="border-t border-teal-deep/10 p-6 dark:border-sky/15 sm:p-7">
          <p class="mb-4 text-muted dark:text-paper/75">Clone the project, install its dependencies and start the local server:</p>
          <pre class="overflow-x-auto rounded-2xl bg-night p-4 text-sm leading-7 text-paper"><code>git clone {SITE_CONFIG.githubUrl}.git
cd se31-website
npm install
npm run dev</code></pre>
          <p class="mt-5 text-sm leading-6 text-muted dark:text-paper/70">Most shared information lives in <code>src/data/deadlines.ts</code>, <code>resources.ts</code>, <code>courses.ts</code> and <code>timetable.ts</code>.</p>
        </div>
      </details>

      <section class="quiet-note">
        <h2 class="mb-3 text-2xl font-semibold">A few ground rules</h2>
        <ul class="list-disc space-y-2 pl-5">
          <li>Do not submit private personal information.</li>
          <li>Do not submit unofficial deadlines without a verifiable source.</li>
          <li>Do not upload copyrighted course material or sensitive academic content.</li>
          <li>Be respectful and constructive in every contribution.</li>
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
