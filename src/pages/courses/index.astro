---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CourseCard from "../../components/CourseCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import { COURSES } from "../../data/courses";
---

<Layout
  title="1A Courses — SE31 Nest"
  description="A skimmable guide to the six first-term Software Engineering courses, based on archived Fall 2025 outlines."
>
  <Navbar />
  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Courses · 1A foundation"
      title="Your first term, course by course."
      description="Get the essential topics, grading breakdown, workload, materials and policies for all six courses—then open the original Waterloo outline when you need the full source."
    >
      <div class="quiet-note mt-7 max-w-4xl text-sm leading-6">
        <strong class="font-bold">Archived reference:</strong> These guides summarize Fall 2025 outlines. Course content, grading, dates and policies can change, so always follow your current instructor and LEARN.
      </div>
    </PageIntro>

    <section class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8" aria-label="First-term course guides">
      <div class="cozy-panel grid overflow-hidden md:grid-cols-2">
        {COURSES.map((course, index) => <CourseCard course={course} index={index} total={COURSES.length} />)}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
