---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import CourseCard from "../../components/CourseCard.astro";
import { COURSES } from "../../data/courses";
---

<Layout
  title="1A Courses - SE31 Hub"
  description="A skimmable guide to the six first-term Software Engineering courses, based on archived Fall 2025 outlines."
>
  <Navbar />
  <main>
    <section class="border-b border-gray-200 dark:border-gray-700 bg-gradient-to-br from-blue-50 via-white to-purple-50 dark:from-gray-900 dark:via-gray-900 dark:to-indigo-950 px-4 py-14 sm:py-20">
      <div class="container mx-auto max-w-5xl">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-blue-700 dark:text-blue-300 mb-4">
          Software Engineering · 1A
        </p>
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-5">
          Your first term, course by course.
        </h1>
        <p class="max-w-3xl text-lg sm:text-xl leading-relaxed text-gray-600 dark:text-gray-300">
          Get the essential topics, grading breakdown, workload, materials, and policies for all six courses—then open the original Waterloo outline when you need the full source.
        </p>

        <div class="mt-8 rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-950/40 px-5 py-4 text-sm text-amber-900 dark:text-amber-100">
          <strong>Archived reference:</strong> These guides summarize Fall 2025 outlines. Course content, grading, dates, and policies can change, so always follow your current instructor and LEARN.
        </div>
      </div>
    </section>

    <section class="container mx-auto px-4 py-12 sm:py-16" aria-labelledby="course-list-heading">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-8">
        <div>
          <p class="text-sm font-semibold text-blue-700 dark:text-blue-300 mb-2">Six required courses</p>
          <h2 id="course-list-heading" class="text-3xl font-bold text-gray-900 dark:text-white">
            Explore the term
          </h2>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Select a guide or open its archived outline directly.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-fr">
        {COURSES.map((course) => <CourseCard course={course} />)}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
