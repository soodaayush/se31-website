---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { COURSES } from "../../data/courses";
import type { Course } from "../../data/types";

export function getStaticPaths() {
  return COURSES.map((course) => ({
    params: { slug: course.slug },
    props: { course },
  }));
}

interface Props {
  course: Course;
}

const { course } = Astro.props;
const base = import.meta.env.BASE_URL;
const courseIndex = COURSES.findIndex((item) => item.slug === course.slug);
const previousCourse = courseIndex > 0 ? COURSES[courseIndex - 1] : undefined;
const nextCourse = courseIndex < COURSES.length - 1 ? COURSES[courseIndex + 1] : undefined;

const sectionLinks = [
  { id: "overview", label: "Overview" },
  { id: "topics", label: "Topics" },
  { id: "outcomes", label: "Learning goals" },
  { id: "grading", label: "Grading" },
  { id: "workload", label: "Workload" },
  { id: "materials", label: "Materials" },
  { id: "policies", label: "Key policies" },
];
---

<Layout title={`${course.code}: ${course.title} — SE31 Nest`} description={course.summary}>
  <Navbar />
  <main id="main-content" tabindex="-1">
    <header class="brand-surface goose-pattern bg-sky px-4 py-10 text-brown dark:bg-sky dark:text-brown sm:py-14">
      <div class="mx-auto max-w-6xl">
        <nav aria-label="Breadcrumb" class="mb-6 text-sm font-semibold text-brown/80">
          <a href={`${base}courses`} class="brand-text-link hover:text-brown">Courses</a>
          <span aria-hidden="true" class="mx-2">›</span>
          <span class="text-brown">{course.code}</span>
        </nav>

        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8">
          <div class="max-w-4xl">
            <div class="mb-3 flex flex-wrap items-center gap-3 text-sm font-semibold text-brown/80">
              <span class="font-display font-semibold text-brown">{course.code}</span>
              <span aria-hidden="true">·</span>
              <span>Based on the {course.archivedTerm} outline</span>
            </div>
            <h1 class="mb-4 text-4xl font-bold leading-[1.04] text-brown sm:text-5xl">
              {course.title}
            </h1>
            <p class="text-lg leading-8 text-brown/85 sm:text-xl">
              {course.summary}
            </p>
            <p class="mt-3 text-sm font-semibold text-brown/80">Archived student reference; your current course may differ.</p>
          </div>

          <a
            href={course.outlineUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="brand-button-primary shrink-0"
          >
            View Waterloo outline ↗
          </a>
        </div>
      </div>
    </header>

    <div class="mx-auto max-w-6xl px-4 py-10 sm:py-14">
      <div class="grid grid-cols-1 lg:grid-cols-[220px_minmax(0,1fr)] gap-10 lg:gap-14">
        <aside>
          <nav aria-label="On this page" class="lg:sticky lg:top-24">
            <p class="mb-3 text-sm font-bold text-teal-deep dark:text-sky">On this page</p>
            <ul class="space-y-2">
              {sectionLinks.map((link) => (
                <li>
                  <a href={`#${link.id}`} class="block rounded-lg px-2 py-1.5 text-sm font-semibold text-muted transition-colors hover:bg-sky/20 hover:text-teal-deep focus-visible:outline focus-visible:outline-3 focus-visible:outline-brown dark:text-paper/70 dark:hover:bg-sky/10 dark:hover:text-sky dark:focus-visible:outline-hardhat">
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </aside>

        <article class="min-w-0 space-y-14">
          <section id="overview" class="scroll-mt-28">
            <h2 class="mb-4 text-3xl font-semibold text-ink dark:text-paper">Overview</h2>
            <p class="mb-7 text-lg leading-8 text-muted dark:text-paper/75">{course.overview}</p>

            <dl class="grid grid-cols-2 overflow-hidden rounded-3xl bg-soft-teal dark:bg-night-panel xl:grid-cols-4">
              {course.highlights.map((highlight, index) => (
                <div
                  class:list={[
                    "p-4 sm:p-5 xl:border-b-0",
                    index < 2 ? "border-b border-teal-deep/10 dark:border-sky/15" : "",
                    index % 2 === 0 ? "border-r border-teal-deep/10 dark:border-sky/15" : "",
                    index < 3 ? "xl:border-r xl:border-teal-deep/10 dark:xl:border-sky/15" : "xl:border-r-0",
                  ]}
                >
                  <dt class="mb-1 text-xs font-semibold text-teal-deep dark:text-sky">{highlight.label}</dt>
                  <dd class="font-bold text-ink dark:text-paper">{highlight.value}</dd>
                </div>
              ))}
            </dl>
          </section>

          <section id="topics" class="scroll-mt-28">
            <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">Core topics</h2>
            <ul class="grid grid-cols-1 border-y border-teal-deep/10 divide-y divide-teal-deep/10 dark:border-sky/15 dark:divide-sky/15 md:grid-cols-2 md:divide-y-0">
              {course.topics.map((topic) => (
                <li class="flex gap-3 px-1 py-4 text-muted dark:text-paper/75 md:pr-6">
                  <span aria-hidden="true" class="mt-2 h-2 w-2 shrink-0 rounded-full bg-teal-deep dark:bg-sky"></span>
                  <span class="leading-relaxed">{topic}</span>
                </li>
              ))}
            </ul>
          </section>

          <section id="outcomes" class="scroll-mt-28">
            <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">What you should learn</h2>
            <ol class="divide-y divide-teal-deep/10 dark:divide-sky/15">
              {course.outcomes.map((outcome, index) => (
                <li class="flex gap-4 py-4 text-ink dark:text-paper">
                  <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-sky/45 text-sm font-bold text-brown dark:bg-sky dark:text-brown">{index + 1}</span>
                  <span class="pt-1 leading-relaxed">{outcome}</span>
                </li>
              ))}
            </ol>
          </section>

          <section id="grading" class="scroll-mt-28">
            <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">Grading breakdown</h2>
            <div class="space-y-6">
              {course.gradingSchemes.map((scheme) => (
                <div class="cozy-panel overflow-hidden">
                  {scheme.name && (
                    <h3 class="border-b border-teal-deep/10 bg-soft-teal px-5 py-3 font-semibold text-ink dark:border-sky/15 dark:bg-night dark:text-paper">{scheme.name}</h3>
                  )}
                  <div class="overflow-x-auto">
                    <table class="w-full text-left">
                      <thead class="bg-sky/12 text-xs text-muted dark:bg-night-panel dark:text-paper/70">
                        <tr>
                          <th scope="col" class="px-5 py-3 font-semibold">Component</th>
                          <th scope="col" class="px-5 py-3 font-semibold">Weight</th>
                          <th scope="col" class="px-5 py-3 font-semibold">What it involved</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-teal-deep/10 bg-panel dark:divide-sky/15 dark:bg-night">
                        {scheme.assessments.map((assessment) => (
                          <tr>
                            <th scope="row" class="px-5 py-4 font-bold text-ink dark:text-paper">{assessment.name}</th>
                            <td class="whitespace-nowrap px-5 py-4 font-bold text-teal-deep dark:text-sky">{assessment.weight}</td>
                            <td class="px-5 py-4 text-sm text-muted dark:text-paper/70">{assessment.detail ?? "—"}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                  {scheme.note && <p class="border-t border-teal-deep/10 bg-soft-teal px-5 py-4 text-sm text-ink dark:border-sky/15 dark:bg-sky/10 dark:text-paper">{scheme.note}</p>}
                </div>
              ))}
            </div>

            {course.gradingNotes.length > 0 && (
              <div class="mt-5 rounded-3xl bg-soft-teal p-5 dark:bg-sky/10">
                <h3 class="mb-3 font-semibold text-ink dark:text-paper">Important grading notes</h3>
                <ul class="space-y-2 text-sm leading-relaxed text-muted dark:text-paper/70">
                  {course.gradingNotes.map((note) => <li class="flex gap-3"><span aria-hidden="true">•</span><span>{note}</span></li>)}
                </ul>
              </div>
            )}
          </section>

          <section id="workload" class="scroll-mt-28">
            <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">What the workload looked like</h2>
            <ul class="space-y-3">
              {course.workload.map((item) => (
                <li class="flex gap-3 leading-relaxed text-muted dark:text-paper/75">
                  <span aria-hidden="true" class="font-bold text-teal-deep dark:text-sky">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </section>

          <section id="materials" class="scroll-mt-28">
            <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">Materials and tools</h2>
            <ul class="divide-y divide-teal-deep/10 border-y border-teal-deep/10 dark:divide-sky/15 dark:border-sky/15">
              {course.materials.map((item) => (
                <li class="flex gap-3 py-4 leading-relaxed text-muted dark:text-paper/75"><span aria-hidden="true" class="text-teal-deep dark:text-sky">•</span><span>{item}</span></li>
              ))}
            </ul>
          </section>

          <section id="policies" class="scroll-mt-28">
            <h2 class="mb-5 text-3xl font-semibold text-ink dark:text-paper">Policies worth noticing</h2>
            <div class="quiet-note p-5">
              <ul class="space-y-3">
                {course.policies.map((policy) => (
                  <li class="flex gap-3 leading-relaxed text-ink dark:text-paper">
                    <span aria-hidden="true" class="font-bold text-signal dark:text-hardhat">!</span>
                    <span>{policy}</span>
                  </li>
                ))}
              </ul>
            </div>
          </section>

          <section class="rounded-3xl bg-teal-deep p-6 text-paper sm:p-8">
            <h2 class="mb-3 text-2xl font-semibold">Need the exact wording?</h2>
            <p class="mb-5 text-paper/85">Open the archived Waterloo outline for full schedules, instructor information, administrative policies and source details.</p>
            <a href={course.outlineUrl} target="_blank" rel="noopener noreferrer" class="brand-button-primary">
              Open full outline ↗
            </a>
          </section>

          <nav aria-label="Other courses" class="grid grid-cols-1 gap-4 border-t border-teal-deep/15 pt-8 dark:border-sky/15 sm:grid-cols-2">
            {previousCourse ? (
              <a href={`${base}courses/${previousCourse.slug}`} class="rounded-xl py-2 focus-visible:outline focus-visible:outline-3 focus-visible:outline-brown dark:focus-visible:outline-hardhat">
                <span class="mb-1 block text-xs font-semibold text-muted dark:text-paper/60">Previous course</span>
                <span class="font-bold text-teal-deep dark:text-sky">← {previousCourse.code}</span>
              </a>
            ) : <span></span>}
            {nextCourse && (
              <a href={`${base}courses/${nextCourse.slug}`} class="rounded-xl py-2 text-right focus-visible:outline focus-visible:outline-3 focus-visible:outline-brown dark:focus-visible:outline-hardhat">
                <span class="mb-1 block text-xs font-semibold text-muted dark:text-paper/60">Next course</span>
                <span class="font-bold text-teal-deep dark:text-sky">{nextCourse.code} →</span>
              </a>
            )}
          </nav>
        </article>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
