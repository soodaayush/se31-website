---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import AnnouncementCard from "../components/AnnouncementCard.astro";
import EmptyState from "../components/EmptyState.astro";
import PageIntro from "../components/PageIntro.astro";
import { ANNOUNCEMENTS } from "../data/announcements";

const announcements = [...ANNOUNCEMENTS].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<Layout
  title="Announcements — SE31 Nest"
  description="Latest announcements for the SE31 cohort."
>
  <Navbar />

  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Cohort notes"
      title="Announcements."
      description="Dated updates worth sharing with the whole cohort, kept separate from official Waterloo notices."
    />

    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
      {
        announcements.length > 0 ? (
          <div class="space-y-6">
            {announcements.map((announcement) => (
              <AnnouncementCard announcement={announcement} />
            ))}
          </div>
        ) : (
          <EmptyState message="No announcements yet." />
        )
      }
    </div>
  </main>

  <Footer />
</Layout>
