---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import AnnouncementCard from "../components/AnnouncementCard.astro";
import EmptyState from "../components/EmptyState.astro";
import { ANNOUNCEMENTS } from "../data/announcements";

const announcements = [...ANNOUNCEMENTS].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<Layout
  title="Announcements - SE31 Hub"
  description="Latest announcements for the SE31 cohort."
>
  <Navbar />

  <main id="main-content" class="container mx-auto px-4 py-8" tabindex="-1">
    <h1 class="text-4xl font-bold text-center mb-8">
      Announcements
    </h1>

    {
      announcements.length > 0 ? (
        <div class="space-y-6">
          {announcements.map((announcement) => (
            <AnnouncementCard announcement={announcement} />
          ))}
        </div>
      ) : (
        <EmptyState message="No announcements yet." />
      )
    }
  </main>

  <Footer />
</Layout>
