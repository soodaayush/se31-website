---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageIntro from "../components/PageIntro.astro";
import { TIMETABLE, TIMETABLE_META } from "../data/timetable";
import { formatTorontoDate } from "../utils/date";

const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

const START = 8 * 60 + 30;
const SLOT_HEIGHT = 40;
function toMinutes(time: string) {
	const [h, m] = time.split(":").map(Number);
	return h * 60 + m;
}

function top(time: string) {
	return ((toMinutes(time) - START) / 30) * SLOT_HEIGHT;
}

function height(start: string, end: string) {
	return ((toMinutes(end) - toMinutes(start)) / 30) * SLOT_HEIGHT;
}

const times = Array.from({ length: 19 }, (_, i) => {
	const mins = START + i * 30;
	const h = Math.floor(mins / 60);
	const m = mins % 60;
	return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
});

const missingLocationCount = TIMETABLE.filter((event) => !event.location).length;
---

<Layout title={`${TIMETABLE_META.term} timetable — SE31 Nest`} description="An unofficial Fall 2026 planning draft for incoming SE31 students, with Quest linked as the current official source.">
	<Navbar />

	<main id="main-content" tabindex="-1">
		<PageIntro
			eyebrow={`Timetable · ${TIMETABLE_META.status}`}
			title={`${TIMETABLE_META.term} weekly timetable.`}
			description={TIMETABLE_META.audience}
		>
			<div class="mt-8 max-w-4xl rounded-2xl border-2 border-brown bg-hardhat/25 p-5 text-sm leading-6 text-brown shadow-[3px_3px_0_#48301f] dark:border-hardhat dark:bg-night-panel dark:text-feather dark:shadow-[3px_3px_0_#f8cb10]">
				<p class="font-black">Unofficial schedule — do not rely on it yet.</p>
				<p>{TIMETABLE_META.notice}</p>
				<p class="mt-3 text-xs font-bold">
					{missingLocationCount} of {TIMETABLE.length} locations unconfirmed · Last checked {formatTorontoDate(TIMETABLE_META.lastChecked)} ·
					{" "}<a href={TIMETABLE_META.sourceUrl} target="_blank" rel="noopener noreferrer" class="brand-text-link focus-visible:outline-spruce dark:focus-visible:outline-lime">{TIMETABLE_META.sourceLabel}</a>
				</p>
			</div>
		</PageIntro>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
		<section aria-labelledby="agenda-heading" class="lg:sr-only">
			<h2 id="agenda-heading" class="mb-4 text-2xl font-bold">Daily agenda</h2>
			<div class="space-y-6">
				{days.map((day) => (
					<section aria-labelledby={`agenda-${day.toLowerCase()}`}>
						<h3 id={`agenda-${day.toLowerCase()}`} class="mb-2 text-xl font-bold">{day}</h3>
						<ol class="space-y-2">
							{TIMETABLE.filter((event) => event.day === day).map((event) => (
								<li class={`rounded-xl border-2 p-3 shadow-[2px_2px_0_rgb(72_48_31_/_0.16)] ${event.color}`}>
									<strong class="text-lg">{event.course} {event.type}</strong>
									<p class="mt-1 text-sm">
										<time datetime={event.start}>{event.start}</time>–<time datetime={event.end}>{event.end}</time>
										<span aria-hidden="true"> · </span>
										<span>{event.location || "Location not confirmed"}</span>
									</p>
								</li>
							))}
						</ol>
					</section>
				))}
			</div>
		</section>

		<div class="hidden overflow-x-auto rounded-2xl border-2 border-brown bg-feather shadow-[4px_4px_0_#48301f] lg:block dark:border-night-border dark:bg-night dark:shadow-[4px_4px_0_#f8cb10]" aria-hidden="true">
			<div
				class="
					grid
					min-w-[930px]
					grid-cols-[80px_repeat(5,minmax(170px,1fr))]
					grid-rows-[44px_auto]
					border-0
					bg-feather
					dark:bg-night
				"
			>
				<div class="border-b-2 border-r-2 border-brown bg-hardhat dark:border-night-border"></div>

				{
					days.map(day => (
						<div
							class="
								flex
								h-11
								items-center
								justify-center
								border-b-2
								border-l-2
								border-brown
								bg-pond
								font-bold
								text-brown
								dark:border-night-border
								dark:bg-pond-deep
								dark:text-brown
							"
						>
							{day}
						</div>
					))
				}

				<div class="flex flex-col bg-feather text-brown dark:bg-night-panel dark:text-feather">
					{
						times.map(time => (
							<div
								class="
									flex
									h-10
									items-center
									justify-center
									border-b
									border-r
									border-brown/20
									text-sm
									dark:border-night-border/60
								"
							>
								{time}
							</div>
						))
					}
				</div>

				{
					days.map(day => (
						<div
							class="
								relative
								flex
								flex-col
								border-l
								border-brown/30
								bg-feather
								dark:border-night-border
								dark:bg-night
							"
						>
							{
								times.map(() => (
									<div
										class="
											h-10
											border-b
											border-brown/15
											box-border
											dark:border-night-border/45
										"
									></div>
								))
							}

							{
								TIMETABLE
									.filter(e => e.day === day)
									.map(event => (
										<div
											class:list={[
												`
													absolute
													left-[1px]
													right-[1px]
													z-[5]
													box-border
													flex
													flex-col
													justify-center
													overflow-hidden
													rounded-lg
													border-2
													px-2
													py-1
													text-[0.8rem]
													leading-tight
													shadow-[2px_2px_0_rgb(72_48_31_/_0.16)]
												`,
											event.color,
											]}
											style={`
												top:${top(event.start)}px;
												height:${height(event.start, event.end)}px;
											`}
										>
											<div class="mb-1 font-bold">
												{event.course} {event.type}
											</div>
							
											<div class="mt-0.5 text-[0.72rem] font-semibold">
												{event.location || "Location TBD"}
											</div>
										</div>
									))
							}
						</div>
					))
				}
			</div>
		</div>
		</div>
	</main>

	<Footer />
</Layout>
