---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { TIMETABLE } from "../data/timetable";

const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

const START_HOUR = 8;
const START_MINUTE = 30;

function minutes(time: string) {
  const [h, m] = time.split(":").map(Number);
  return h * 60 + m;
}

const startMinutes = START_HOUR * 60 + START_MINUTE;

function top(start: string) {
  return ((minutes(start) - startMinutes) / 30) * 48;
}

function height(start: string, end: string) {
  return ((minutes(end) - minutes(start)) / 30) * 48;
}
---

<Layout title="Timetable - SE31 Hub">
    <Navbar />

    <main class="container mx-auto px-4 py-8">
        <h1 class="text-4xl font-bold text-center mb-8">
            Weekly Timetable
        </h1>

        <div class="overflow-x-auto">
            <div class="schedule">

                <!-- Top-left corner -->
                <div class="corner"></div>

                <!-- Day headers -->
                {
                    days.map(day => (
                        <div class="day-header">{day}</div>
                    ))
                }

                <!-- Time column -->
                <div class="times">
                    {
                        Array.from({ length: 19 }).map((_, i) => {
                            const mins = startMinutes + i * 30;
                            const h = Math.floor(mins / 60);
                            const m = mins % 60;

                            return (
                                <div class="time">
                                    {`${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`}
                                </div>
                            );
                        })
                    }
                </div>

                <!-- Days -->
                {
                    days.map(day => (
                        <div class="day-column">

                            <!-- Background -->
                            {
                                Array.from({ length: 19 }).map(() => (
                                    <div class="slot"></div>
                                ))
                            }

                            <!-- Events -->
                            {
                                TIMETABLE
                                    .filter(e => e.day === day)
                                    .map(event => (
                                        <div
                                            class="event"
                                            style={`
                                                top:${top(event.start)}px;
                                                height:${height(event.start, event.end)}px;
                                                background:${event.color};
                                            `}
                                        >
                                            <strong>{event.course}</strong><br />
                                            {event.type}
                                            {
                                                event.location &&
                                                <>
                                                    <br />
                                                    <small>{event.location}</small>
                                                </>
                                            }
                                        </div>
                                    ))
                            }
                        </div>
                    ))
                }

            </div>
        </div>
    </main>

    <Footer />
</Layout>

<style>
.schedule {
    display: grid;
    grid-template-columns: 80px repeat(5, 1fr);
    grid-template-rows: 48px auto;
    min-width: 950px;
    border: 1px solid rgb(209 213 219);
}

.corner {
    border-right: 1px solid rgb(209 213 219);
    border-bottom: 1px solid rgb(209 213 219);
}

.day-header {
    display: flex;
    justify-content: center;
    align-items: center;
    font-weight: bold;
    border-left: 1px solid rgb(209 213 219);
    border-bottom: 1px solid rgb(209 213 219);
    background: rgb(243 244 246);
}

.times {
    display: flex;
    flex-direction: column;
}

.time {
    height: 48px;
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    padding-right: .5rem;
    padding-top: .2rem;
    font-size: .8rem;
    border-right: 1px solid rgb(209 213 219);
    border-bottom: 1px solid rgb(229 231 235);
}

.day-column {
    position: relative;
    display: flex;
    flex-direction: column;
    border-left: 1px solid rgb(209 213 219);
}

.slot {
    height: 48px;
    border-bottom: 1px solid rgb(229 231 235);
}

.event {
    position: absolute;
    left: 4px;
    right: 4px;

    padding: .4rem;
    border-radius: .5rem;
    border: 1px solid rgba(0,0,0,.15);

    font-size: .8rem;
    overflow: hidden;
    box-sizing: border-box;
}

.dark .day-header {
    background: rgb(31 41 55);
}

.dark .schedule,
.dark .corner,
.dark .day-header,
.dark .time,
.dark .day-column {
    border-color: rgb(75 85 99);
}

.dark .slot {
    border-color: rgb(55 65 81);
}
</style>
