---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageIntro from "../components/PageIntro.astro";
import { TIMETABLE, TIMETABLE_META } from "../data/timetable";
import { formatTorontoDate } from "../utils/date";

const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

const START = 8 * 60 + 30;
const SLOT_HEIGHT = 40;
function toMinutes(time: string) {
	const [h, m] = time.split(":").map(Number);
	return h * 60 + m;
}

function top(time: string) {
	return ((toMinutes(time) - START) / 30) * SLOT_HEIGHT;
}

function height(start: string, end: string) {
	return ((toMinutes(end) - toMinutes(start)) / 30) * SLOT_HEIGHT;
}

const times = Array.from({ length: 19 }, (_, i) => {
	const mins = START + i * 30;
	const h = Math.floor(mins / 60);
	const m = mins % 60;
	return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
});

const missingLocationCount = TIMETABLE.filter((event) => !event.location).length;
---

<Layout title={`${TIMETABLE_META.term} timetable — SE31 Nest`} description="An unofficial Fall 2026 planning draft for incoming SE31 students, with Quest linked as the current official source.">
	<Navbar />

	<main id="main-content" tabindex="-1">
		<PageIntro
			eyebrow={`Timetable · ${TIMETABLE_META.status}`}
			title={`${TIMETABLE_META.term} weekly timetable.`}
			description={TIMETABLE_META.audience}
		>
			<div class="quiet-note mt-7 max-w-4xl text-sm leading-6">
				<p class="font-bold">Unofficial schedule — do not rely on it yet.</p>
				<p>{TIMETABLE_META.notice}</p>
				<p class="mt-3 text-xs font-bold">
					{missingLocationCount} of {TIMETABLE.length} locations unconfirmed · Last checked {formatTorontoDate(TIMETABLE_META.lastChecked)} ·
					{" "}<a href={TIMETABLE_META.sourceUrl} target="_blank" rel="noopener noreferrer" class="brand-text-link">{TIMETABLE_META.sourceLabel}</a>
				</p>
			</div>
		</PageIntro>

		<div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
			<section aria-labelledby="agenda-heading" class="lg:sr-only">
				<h2 id="agenda-heading" class="mb-4 text-2xl font-bold">Daily agenda</h2>
				<div class="space-y-6">
					{days.map((day) => (
						<section aria-labelledby={`agenda-${day.toLowerCase()}`}>
							<h3 id={`agenda-${day.toLowerCase()}`} class="mb-2 text-xl font-bold">{day}</h3>
							<ol class="cozy-panel divide-y divide-teal-deep/10 overflow-hidden dark:divide-sky/15">
								{TIMETABLE.filter((event) => event.day === day).map((event) => (
									<li class="p-4 sm:p-5">
										<strong class:list={["inline-flex rounded-lg border px-2.5 py-1 text-sm font-bold", event.color]}>
											{event.course} {event.type}
										</strong>
										<p class="mt-1 text-sm">
											<time datetime={event.start}>{event.start}</time>–<time datetime={event.end}>{event.end}</time>
											<span aria-hidden="true"> · </span>
											<span>{event.location || "Location not confirmed"}</span>
										</p>
									</li>
								))}
							</ol>
						</section>
					))}
				</div>
			</section>

		<div class="hidden overflow-x-auto rounded-3xl border border-teal-deep/15 bg-feather lg:block dark:border-sky/20 dark:bg-night" aria-hidden="true">
			<div
				class="
					grid
					min-w-[930px]
					grid-cols-[80px_repeat(5,minmax(170px,1fr))]
					grid-rows-[44px_auto]
					border-0
					bg-feather
					dark:bg-night
				"
			>
				<div class="border-b border-r border-teal-deep/15 bg-soft-teal dark:border-sky/15 dark:bg-night-panel"></div>

				{
					days.map(day => (
						<div
							class="
								flex
								h-11
								items-center
								justify-center
								border-b
								border-l
								border-teal-deep/15
								bg-pond
								font-bold
								text-brown
								dark:border-sky/15
								dark:bg-pond-deep
								dark:text-brown
							"
						>
							{day}
						</div>
					))
				}

				<div class="flex flex-col bg-feather text-brown dark:bg-night-panel dark:text-feather">
					{
						times.map(time => (
							<div
								class="
									flex
									h-10
									items-center
									justify-center
									border-b
									border-r
									border-teal-deep/10
									text-sm
									dark:border-sky/10
								"
							>
								{time}
							</div>
						))
					}
				</div>

				{
					days.map(day => (
						<div
							class="
								relative
								flex
								flex-col
								border-l
								border-teal-deep/12
								bg-feather
								dark:border-sky/15
								dark:bg-night
							"
						>
							{
								times.map(() => (
									<div
										class="
											h-10
											border-b
											border-teal-deep/8
											box-border
											dark:border-sky/10
										"
									></div>
								))
							}

							{
								TIMETABLE
									.filter(e => e.day === day)
									.map(event => (
										<div
											class:list={[
												`
													absolute
													left-[1px]
													right-[1px]
													z-[5]
													box-border
													flex
													flex-col
													justify-center
												overflow-hidden
												rounded-lg
												border
													px-2
													py-1
													text-[0.8rem]
													leading-tight
												`,
											event.color,
											]}
											style={`
												top:${top(event.start)}px;
												height:${height(event.start, event.end)}px;
											`}
										>
											<div class="mb-1 font-bold">
											{event.course} {event.type}
										</div>

											<div class="mt-0.5 text-[0.72rem] font-semibold">
												{event.location || "Location TBD"}
											</div>
										</div>
									))
							}
						</div>
					))
				}
			</div>
		</div>
		</div>
	</main>

	<Footer />
</Layout>
