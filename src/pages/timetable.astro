---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { TIMETABLE } from "../data/timetable";

const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

const START = 8 * 60 + 30;
const SLOT_HEIGHT = 48;

function toMinutes(time: string) {
	const [h, m] = time.split(":").map(Number);
	return h * 60 + m;
}

function top(time: string) {
	return ((toMinutes(time) - START) / 30) * SLOT_HEIGHT;
}

function height(start: string, end: string) {
	return ((toMinutes(end) - toMinutes(start)) / 30) * SLOT_HEIGHT;
}

const times = Array.from({ length: 19 }, (_, i) => {
	const mins = START + i * 30;
	const h = Math.floor(mins / 60);
	const m = mins % 60;
	return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
});
---

<Layout title="Timetable - SE31 Hub">
	<Navbar />

	<main class="container mx-auto px-4 py-8">
		<h1 class="mb-8 text-center text-4xl font-bold">
			Weekly Timetable
		</h1>

		<div class="overflow-x-auto">
			<div
				class="
					grid
					min-w-[930px]
					grid-cols-[80px_repeat(5,minmax(170px,1fr))]
					grid-rows-[48px_auto]
					border
					border-gray-300
					bg-white
					dark:border-gray-600
					dark:bg-gray-900
				"
			>
				<div class="border-b border-r border-gray-300 dark:border-gray-600"></div>

				{
					days.map(day => (
						<div
							class="
								flex
								h-12
								items-center
								justify-center
								border-b
								border-l
								border-gray-300
								bg-gray-100
								font-bold
								dark:border-gray-600
								dark:bg-gray-800
								dark:text-gray-100
							"
						>
							{day}
						</div>
					))
				}

				<div class="flex flex-col bg-white dark:bg-gray-900">
					{
						times.map(time => (
							<div
								class="
									flex
									h-12
									items-center
									justify-center
									border-b
									border-r
									border-gray-200
									text-sm
									dark:border-gray-700
									dark:text-gray-300
								"
							>
								{time}
							</div>
						))
					}
				</div>

				{
					days.map(day => (
						<div
							class="
								relative
								flex
								flex-col
								border-l
								border-gray-300
								bg-white
								dark:border-gray-600
								dark:bg-gray-900
							"
						>
							{
								times.map(() => (
									<div
										class="
											h-12
											border-b
											border-gray-200
											box-border
											dark:border-gray-700
										"
									></div>
								))
							}

							{
								TIMETABLE
									.filter(e => e.day === day)
									.map(event => (
										<div
											class:list={[
												`
													absolute
													left-[1px]
													right-[1px]
													z-[5]
													box-border
													flex
													flex-col
													justify-center
													overflow-hidden
													rounded-lg
													border
													border-black/10
													p-2
													text-[0.8rem]
													leading-tight
													shadow-sm
													dark:border-white/15
												`,
												event.color,
											]}
											style={`
												top:${top(event.start)}px;
												height:${height(event.start, event.end)}px;
											`}
										>
											<div class="mb-1 font-bold">
												{event.course}
											</div>
							
											<div>{event.type}</div>
							
											{
												event.location && (
													<div class="mt-1 text-[0.72rem] opacity-80">
														{event.location}
													</div>
												)
											}
										</div>
									))
							}
						</div>
					))
				}
			</div>
		</div>
	</main>

	<Footer />
</Layout>

<style>
@media (max-width: 768px) {
	.grid {
		min-width: 900px;
	}
}
</style>
