---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { TIMETABLE } from "../data/timetable";

const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

const START = 8 * 60 + 30;
const SLOT_HEIGHT = 48;
const HEADER_HEIGHT = 48;

function toMinutes(time: string) {
	const [h, m] = time.split(":").map(Number);
	return h * 60 + m;
}

function top(time: string) {
	return ((toMinutes(time) - START) / 30) * SLOT_HEIGHT;
}

function height(start: string, end: string) {
	return ((toMinutes(end) - toMinutes(start)) / 30) * SLOT_HEIGHT;
}

const times = Array.from({ length: 19 }, (_, i) => {
	const mins = START + i * 30;
	const h = Math.floor(mins / 60);
	const m = mins % 60;
	return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
});
---

<Layout title="Timetable - SE31 Hub">
	<Navbar />

	<main class="container mx-auto px-4 py-8">
		<h1 class="text-4xl font-bold text-center mb-8">
			Weekly Timetable
		</h1>

		<div class="overflow-x-auto">

			<div class="table">

				<div class="corner"></div>

				{
					days.map(day => (
						<div class="header">{day}</div>
					))
				}

				<div class="times">
					{
						times.map(time => (
							<div class="time">{time}</div>
						))
					}
				</div>

				{
					days.map(day => (
						<div class="column">

							{
								times.map(() => (
									<div class="slot"></div>
								))
							}

							{
								TIMETABLE
									.filter(e => e.day === day)
									.map(event => (
										<div
											class="lesson"
											style={`
												top:${top(event.start)}px;
												height:${height(event.start, event.end)}px;
												background:${event.color};
											`}
										>
											<div class="course">{event.course}</div>
											<div>{event.type}</div>

											{
												event.location &&
												<div class="location">
													{event.location}
												</div>
											}
										</div>
									))
							}

						</div>
					))
				}

			</div>

		</div>
	</main>

	<Footer />
</Layout>

<style>
.table {
	display: grid;
	grid-template-columns: 80px repeat(5, minmax(170px, 1fr));
	grid-template-rows: 48px auto;

	min-width: 930px;

	border: 1px solid rgb(209 213 219);
	background: white;
}

.corner {
	border-right: 1px solid rgb(209 213 219);
	border-bottom: 1px solid rgb(209 213 219);
	background: inherit;
}

.header {
	height: 48px;

	display: flex;
	align-items: center;
	justify-content: center;

	font-weight: 700;

	background: rgb(243 244 246);

	border-left: 1px solid rgb(209 213 219);
	border-bottom: 1px solid rgb(209 213 219);
}

.times {
	display: flex;
	flex-direction: column;

	background: inherit;
}

.time {
	height: 48px;

	display: flex;
	align-items: center;
	justify-content: center;

	font-size: 0.8rem;

	border-right: 1px solid rgb(209 213 219);
	border-bottom: 1px solid rgb(229 231 235);
}

.column {
	position: relative;

	display: flex;
	flex-direction: column;

	background: inherit;

	border-left: 1px solid rgb(209 213 219);
}

.slot {
	height: 48px;

	border-bottom: 1px solid rgb(229 231 235);

	box-sizing: border-box;
}

.lesson {
	position: absolute;

	left: 1px;
	right: 1px;

	padding: 0.5rem;

	border-radius: 0.5rem;
	border: 1px solid rgba(0, 0, 0, 0.12);

	box-sizing: border-box;

	display: flex;
	flex-direction: column;
	justify-content: center;

	font-size: 0.8rem;
	line-height: 1.2;

	overflow: hidden;

	z-index: 5;
}

.course {
	font-weight: 700;
	margin-bottom: 0.2rem;
}

.location {
	font-size: 0.72rem;
	opacity: 0.8;
	margin-top: 0.15rem;
}

/* ---------- Dark mode ---------- */

:global(html.dark) .table {
	background: rgb(17 24 39);
	border-color: rgb(75 85 99);
}

:global(html.dark) .corner {
	background: rgb(17 24 39);
	border-color: rgb(75 85 99);
}

:global(html.dark) .header {
	background: rgb(31 41 55);
	color: rgb(243 244 246);

	border-color: rgb(75 85 99);
}

:global(html.dark) .times {
	background: rgb(17 24 39);
}

:global(html.dark) .time {
	background: rgb(17 24 39);
	color: rgb(209 213 219);

	border-color: rgb(55 65 81);
}

:global(html.dark) .column {
	background: rgb(17 24 39);
	border-color: rgb(75 85 99);
}

:global(html.dark) .slot {
	border-color: rgb(55 65 81);
}

:global(html.dark) .lesson {
	border-color: rgba(255, 255, 255, 0.15);
}

/* ---------- Responsive ---------- */

@media (max-width: 768px) {
	.table {
		min-width: 900px;
	}
}
</style>
