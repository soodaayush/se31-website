---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { TIMETABLE, TIMETABLE_META } from "../data/timetable";
import { formatTorontoDate } from "../utils/date";

const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

const START = 8 * 60 + 30;
const SLOT_HEIGHT = 48;
function toMinutes(time: string) {
	const [h, m] = time.split(":").map(Number);
	return h * 60 + m;
}

function top(time: string) {
	return ((toMinutes(time) - START) / 30) * SLOT_HEIGHT;
}

function height(start: string, end: string) {
	return ((toMinutes(end) - toMinutes(start)) / 30) * SLOT_HEIGHT;
}

const times = Array.from({ length: 19 }, (_, i) => {
	const mins = START + i * 30;
	const h = Math.floor(mins / 60);
	const m = mins % 60;
	return `${String(h).padStart(2, "0")}:${String(m).padStart(2, "0")}`;
});

const missingLocationCount = TIMETABLE.filter((event) => !event.location).length;
---

<Layout title={`${TIMETABLE_META.term} Timetable - SE31 Hub`} description="A clearly labelled draft reference timetable for incoming SE31 students.">
	<Navbar />

	<main id="main-content" class="container mx-auto px-4 py-8" tabindex="-1">
		<div class="mx-auto mb-8 max-w-4xl text-center">
			<p class="mb-2 text-sm font-bold uppercase tracking-[0.18em] text-blue-700 dark:text-blue-300">
				{TIMETABLE_META.status}
			</p>
			<h1 class="mb-3 text-4xl font-bold">{TIMETABLE_META.term} Weekly Timetable</h1>
			<p class="text-gray-700 dark:text-gray-300">{TIMETABLE_META.audience}</p>
		</div>

		<div class="mx-auto mb-8 max-w-4xl rounded-xl border border-amber-300 bg-amber-50 p-5 text-amber-950 dark:border-amber-800 dark:bg-amber-950/40 dark:text-amber-100">
			<p class="font-bold">Draft schedule — verify before relying on it.</p>
			<p class="mt-1">{TIMETABLE_META.notice}</p>
			<p class="mt-3 text-sm">
				{missingLocationCount} of {TIMETABLE.length} entries still have unconfirmed locations · Updated {formatTorontoDate(TIMETABLE_META.lastUpdated)} ·
				{" "}<a href={TIMETABLE_META.sourceUrl} target="_blank" rel="noopener noreferrer" class="font-semibold underline underline-offset-2 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-700">{TIMETABLE_META.sourceLabel}</a>
			</p>
		</div>

		<section aria-labelledby="agenda-heading" class="lg:sr-only">
			<h2 id="agenda-heading" class="mb-5 text-2xl font-bold">Daily agenda</h2>
			<div class="space-y-8">
				{days.map((day) => (
					<section aria-labelledby={`agenda-${day.toLowerCase()}`}>
						<h3 id={`agenda-${day.toLowerCase()}`} class="mb-3 text-xl font-bold">{day}</h3>
						<ol class="space-y-3">
							{TIMETABLE.filter((event) => event.day === day).map((event) => (
								<li class={`rounded-xl border border-black/10 p-4 shadow-sm dark:border-white/15 ${event.color}`}>
									<div class="flex flex-wrap items-baseline justify-between gap-2">
										<strong class="text-lg">{event.course}</strong>
										<span class="text-sm font-semibold">{event.type}</span>
									</div>
									<p class="mt-2 text-sm">
										<time datetime={event.start}>{event.start}</time>–<time datetime={event.end}>{event.end}</time>
										<span aria-hidden="true"> · </span>
										<span>{event.location || "Location not confirmed"}</span>
									</p>
								</li>
							))}
						</ol>
					</section>
				))}
			</div>
		</section>

		<div class="hidden overflow-x-auto lg:block" aria-hidden="true">
			<div
				class="
					grid
					min-w-[930px]
					grid-cols-[80px_repeat(5,minmax(170px,1fr))]
					grid-rows-[48px_auto]
					border
					border-gray-300
					bg-white
					dark:border-gray-600
					dark:bg-gray-900
				"
			>
				<div class="border-b border-r border-gray-300 dark:border-gray-600"></div>

				{
					days.map(day => (
						<div
							class="
								flex
								h-12
								items-center
								justify-center
								border-b
								border-l
								border-gray-300
								bg-gray-100
								font-bold
								dark:border-gray-600
								dark:bg-gray-800
								dark:text-gray-100
							"
						>
							{day}
						</div>
					))
				}

				<div class="flex flex-col bg-white dark:bg-gray-900">
					{
						times.map(time => (
							<div
								class="
									flex
									h-12
									items-center
									justify-center
									border-b
									border-r
									border-gray-200
									text-sm
									dark:border-gray-700
									dark:text-gray-300
								"
							>
								{time}
							</div>
						))
					}
				</div>

				{
					days.map(day => (
						<div
							class="
								relative
								flex
								flex-col
								border-l
								border-gray-300
								bg-white
								dark:border-gray-600
								dark:bg-gray-900
							"
						>
							{
								times.map(() => (
									<div
										class="
											h-12
											border-b
											border-gray-200
											box-border
											dark:border-gray-700
										"
									></div>
								))
							}

							{
								TIMETABLE
									.filter(e => e.day === day)
									.map(event => (
										<div
											class:list={[
												`
													absolute
													left-[1px]
													right-[1px]
													z-[5]
													box-border
													flex
													flex-col
													justify-center
													overflow-hidden
													rounded-lg
													border
													border-black/10
													p-2
													text-[0.8rem]
													leading-tight
													shadow-sm
													dark:border-white/15
												`,
											event.color,
											]}
											style={`
												top:${top(event.start)}px;
												height:${height(event.start, event.end)}px;
											`}
										>
											<div class="mb-1 font-bold">
												{event.course}
											</div>
							
											<div>{event.type}</div>
							
											<div class="mt-1 text-[0.72rem] opacity-80">
												{event.location || "Location TBD"}
											</div>
										</div>
									))
							}
						</div>
					))
				}
			</div>
		</div>
	</main>

	<Footer />
</Layout>
