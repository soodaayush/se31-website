---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import DeadlineCard from "../components/DeadlineCard.astro";
import EmptyState from "../components/EmptyState.astro";
import PageIntro from "../components/PageIntro.astro";
import { DEADLINES } from "../data/deadlines";
import { getDeadlineStartTime, getDeadlineStatus } from "../utils/date";

const now = new Date();

const ongoingDeadlines = DEADLINES.filter(d => getDeadlineStatus(d, now) === "ongoing")
  .sort((a, b) => getDeadlineStartTime(a) - getDeadlineStartTime(b));

const upcomingDeadlines = DEADLINES.filter(d => getDeadlineStatus(d, now) === "upcoming")
  .sort((a, b) => getDeadlineStartTime(a) - getDeadlineStartTime(b));

const pastDeadlines = DEADLINES.filter(d => getDeadlineStatus(d, now) === "past")
  .sort((a, b) => getDeadlineStartTime(b) - getDeadlineStartTime(a));
---

<Layout title="Deadlines — SE31 Nest" description="Important public cohort deadlines for SE31.">
  <Navbar />
  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Dates · Source checked"
      title="Important deadlines."
      description="A public record of the dates that shape our transition into 1A, with the official source attached to every entry."
    >
      <div class="quiet-note mt-7 max-w-4xl text-sm leading-6">
        <p class="font-bold">Use the official source for final confirmation.</p>
        <p>Every entry shows when its source was last checked. Statuses are refreshed daily.</p>
      </div>
    </PageIntro>

    <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
      {ongoingDeadlines.length > 0 && (
        <section class="mb-14" aria-labelledby="ongoing-heading">
          <h2 id="ongoing-heading" class="mb-6 text-3xl font-semibold text-ink dark:text-paper">Happening now</h2>
          <div class="cozy-panel divide-y divide-teal-deep/10 overflow-hidden dark:divide-sky/15">
            {ongoingDeadlines.map((deadline) => (
              <DeadlineCard deadline={deadline} status="ongoing" />
            ))}
          </div>
        </section>
      )}

      <section class="mb-14" aria-labelledby="upcoming-heading">
        <h2 id="upcoming-heading" class="mb-6 text-3xl font-semibold text-ink dark:text-paper">Coming up</h2>
        {upcomingDeadlines.length > 0 ? (
        <div class="cozy-panel divide-y divide-teal-deep/10 overflow-hidden dark:divide-sky/15">
          {upcomingDeadlines.map((deadline) => (
            <DeadlineCard deadline={deadline} status="upcoming" />
          ))}
        </div>
        ) : (
          <EmptyState message="No upcoming deadlines at the moment. Check back soon!" />
        )}
      </section>

      <section aria-labelledby="past-heading">
        <h2 id="past-heading" class="mb-6 text-3xl font-semibold text-ink dark:text-paper">Archive</h2>
        {pastDeadlines.length > 0 ? (
          <div class="cozy-panel divide-y divide-teal-deep/10 overflow-hidden dark:divide-sky/15">
            {pastDeadlines.map((deadline) => (
              <DeadlineCard deadline={deadline} status="past" />
            ))}
          </div>
        ) : (
          <EmptyState message="No past deadlines to display." />
        )}
      </section>
    </div>
  </main>
  <Footer />
</Layout>
