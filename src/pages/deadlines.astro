---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import DeadlineCard from "../components/DeadlineCard.astro";
import EmptyState from "../components/EmptyState.astro";
import { SITE_CONFIG } from "../data/siteConfig";
import { DEADLINES } from "../data/deadlines";

const now = new Date();

const upcomingDeadlines = DEADLINES.filter(d => new Date(d.date) > now)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime());

const pastDeadlines = DEADLINES.filter(d => new Date(d.date) <= now)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()); // Sort past deadlines newest first
---

<Layout title="Deadlines - SE31 Hub" description="Important public cohort deadlines for SE31.">
  <Navbar />
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-4xl font-bold text-center mb-8">Important Deadlines</h1>

    <div class="bg-yellow-100 dark:bg-yellow-900 border-l-4 border-yellow-500 text-yellow-700 dark:text-yellow-300 p-4 mb-8" role="alert">
      <p class="font-bold">Notice:</p>
      <p>Always confirm academic and administrative deadlines through official University of Waterloo sources.</p>
    </div>

    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">Upcoming Deadlines</h2>
      {upcomingDeadlines.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {upcomingDeadlines.map((deadline) => (
            <DeadlineCard deadline={deadline} />
          ))}
        </div>
      ) : (
        <EmptyState message="No upcoming deadlines at the moment. Check back soon!" />
      )}
    </section>

    <section>
      <h2 class="text-3xl font-bold mb-6">Past Deadlines</h2>
      {pastDeadlines.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {pastDeadlines.map((deadline) => (
            <DeadlineCard deadline={deadline} isPast={true} />
          ))}
        </div>
      ) : (
        <EmptyState message="No past deadlines to display." />
      )}
    </section>
  </main>
  <Footer />
</Layout>
