---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ResourceCard from "../components/ResourceCard.astro";
import EmptyState from "../components/EmptyState.astro";
import PageIntro from "../components/PageIntro.astro";
import { RESOURCES } from "../data/resources";

const base = import.meta.env.BASE_URL;

const allCategories = Array.from(new Set(RESOURCES.map(r => r.category))).sort();
const categoryId = (category: string) => `resources-${category.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
---

<Layout title="Resources — SE31 Nest" description="Curated resources for the SE31 cohort.">
  <Navbar />
  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Links · Curated"
      title="Cohort resources."
      description="A short, maintained index of the Waterloo services, academic references and practical tools worth keeping nearby."
    >
      <div class="mt-7 max-w-4xl text-sm leading-6 text-brown/80">
        <strong class="font-bold">Curated, not exhaustive.</strong> Verify important information with official sources. Have a link worth keeping? <a href={`${base}contribute`} class="brand-text-link font-bold">Share it with the cohort.</a>
      </div>
    </PageIntro>

    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
      {allCategories.length > 0 ? (
        allCategories.map(category => (
          <section class="mb-14 last:mb-0" aria-labelledby={categoryId(category)}>
            <h2 id={categoryId(category)} class="mb-5 text-3xl font-semibold capitalize text-ink dark:text-paper">{category}</h2>
            <div class="cozy-panel divide-y divide-teal-deep/10 overflow-hidden dark:divide-sky/15">
              {RESOURCES.filter(r => r.category === category).map(resource => (
                <ResourceCard resource={resource} />
              ))}
            </div>
          </section>
        ))
      ) : (
        <EmptyState message="No resources available yet. Be the first to add some!" />
      )}
    </div>
  </main>
  <Footer />
</Layout>
