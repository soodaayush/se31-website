---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ResourceCard from "../components/ResourceCard.astro";
import EmptyState from "../components/EmptyState.astro";
import PageIntro from "../components/PageIntro.astro";
import { QUICK_LAUNCH, RESOURCES } from "../data/resources";

const base = import.meta.env.BASE_URL;

const allCategories = Array.from(new Set(RESOURCES.map(r => r.category))).sort();
const categoryId = (category: string) => `resources-${category.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
const quickLaunchResources = QUICK_LAUNCH.flatMap((item) => {
  const resource = RESOURCES.find((candidate) => candidate.title === item.resourceTitle);
  return resource ? [{ ...resource, label: item.label, mark: item.mark }] : [];
});
---

<Layout title="Resources — SE31 Nest" description="Curated resources for the SE31 cohort.">
  <Navbar />
  <main id="main-content" tabindex="-1">
    <PageIntro
      eyebrow="Links · Curated"
      title="Cohort resources."
      description="Open the Waterloo platforms you use every day, or browse a maintained index of academic references and practical tools."
    >
      {quickLaunchResources.length > 0 && (
        <nav
          class="mt-7 flex max-w-6xl flex-col gap-2 rounded-2xl bg-feather/85 p-2.5 shadow-[0_10px_28px_rgb(72_48_31_/_0.08)] backdrop-blur-sm lg:flex-row lg:items-center"
          aria-labelledby="quick-launch-heading"
        >
          <div class="shrink-0 px-2 py-1 sm:w-32">
            <h2 id="quick-launch-heading" class="text-base font-semibold text-brown">Quick launch</h2>
            <p class="text-xs font-semibold text-brown/65">Everyday tools</p>
          </div>

          <ul class="grid min-w-0 flex-1 grid-cols-2 gap-1.5 sm:grid-cols-3 lg:grid-cols-5">
            {quickLaunchResources.map((resource) => (
              <li class="min-w-0">
                <a
                  href={resource.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex min-h-11 items-center gap-2 rounded-xl px-2 text-xs font-bold leading-tight text-brown transition-colors hover:bg-sky/30 focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-[-3px] focus-visible:outline-brown sm:px-2.5 sm:text-sm"
                >
                  <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-sky text-xs font-bold text-brown" aria-hidden="true">
                    {resource.mark}
                  </span>
                  <span class="min-w-0">{resource.label}</span>
                  <span class="ml-auto hidden text-xs text-teal-deep transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5 motion-reduce:transition-none lg:inline" aria-hidden="true">↗</span>
                  <span class="sr-only"> (opens in a new tab)</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      <div class="mt-4 max-w-4xl text-sm leading-6 text-brown/80">
        <strong class="font-bold">Curated, not exhaustive.</strong> Verify important information with official sources. Have a link worth keeping? <a href={`${base}contribute`} class="brand-text-link font-bold">Share it with the cohort.</a>
      </div>
    </PageIntro>

    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 sm:py-16 lg:px-8">
      {allCategories.length > 0 ? (
        allCategories.map(category => (
          <section class="mb-14 last:mb-0" aria-labelledby={categoryId(category)}>
            <h2 id={categoryId(category)} class="mb-5 text-3xl font-semibold capitalize text-ink dark:text-paper">{category}</h2>
            <div class="cozy-panel divide-y divide-teal-deep/10 overflow-hidden dark:divide-sky/15">
              {RESOURCES.filter(r => r.category === category).map(resource => (
                <ResourceCard resource={resource} />
              ))}
            </div>
          </section>
        ))
      ) : (
        <EmptyState message="No resources available yet. Be the first to add some!" />
      )}
    </div>
  </main>
  <Footer />
</Layout>
