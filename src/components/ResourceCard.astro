---
import type { Resource } from "../data/types";

interface Props {
  resource: Resource;
}

const { resource } = Astro.props;
---

<a
  href={resource.url}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex items-center justify-between gap-5 p-5 transition-colors hover:bg-sky/12 focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-[-3px] focus-visible:outline-brown dark:hover:bg-sky/8 dark:focus-visible:outline-hardhat sm:p-6"
>
  <div class="min-w-0">
    <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
      <h3 class="text-xl font-semibold text-ink dark:text-paper">{resource.title}</h3>
      {resource.official && <span class="text-xs font-semibold text-teal-deep dark:text-sky">Official Waterloo source</span>}
    </div>
    <p class="mt-2 leading-7 text-muted dark:text-paper/70">{resource.description}</p>
  </div>
  <span class="shrink-0 text-lg font-bold text-teal-deep dark:text-sky" aria-hidden="true">↗</span>
</a>
