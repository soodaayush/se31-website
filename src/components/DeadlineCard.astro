---
import type { Deadline } from "../data/types";
import Badge from "./Badge.astro";
import Countdown from "./Countdown.tsx";
import {
  formatTorontoDate,
  formatTorontoDateTime,
  getDeadlineStatus,
  type DeadlineStatus,
} from "../utils/date";

interface Props {
  deadline: Deadline;
  status?: DeadlineStatus;
}

const { deadline, status: suppliedStatus } = Astro.props;
const status = suppliedStatus ?? getDeadlineStatus(deadline);
const isPast = status === "past";
const isOngoing = status === "ongoing";
const isCountdownEligible = deadline.deadlineType === "action" && deadline.startDate.length > 10;
---

<article class="grid gap-4 p-6 sm:p-7 md:grid-cols-[11rem_minmax(0,1fr)] md:gap-7">
  <div>
    <p class:list={["font-semibold leading-6", isPast ? "text-muted dark:text-paper/60" : "text-ink dark:text-paper"]}>
      {formatTorontoDateTime(deadline.startDate)}
      {deadline.endDate && <><br /><span class="text-sm">to {formatTorontoDateTime(deadline.endDate)}</span></>}
    </p>
    <p class="mt-2 text-xs font-semibold capitalize text-teal-deep dark:text-sky">
      {deadline.category} · {deadline.deadlineType === "action" ? "Action" : "Event"}
    </p>
  </div>

  <div class="min-w-0">
    <div class="flex flex-wrap items-start justify-between gap-3">
      <h3 class:list={["text-xl font-semibold leading-tight sm:text-2xl", isPast ? "text-muted dark:text-paper/65" : "text-ink dark:text-paper"]}>
        {deadline.title}
      </h3>
      <div class="flex flex-wrap gap-2">
        {isOngoing && <Badge text="Happening now" color="bg-sky" textColor="text-brown" />}
        {deadline.priority === "high" && !isPast && <Badge text="High priority" color="bg-hardhat" textColor="text-brown" />}
        {!deadline.verified && <Badge text="Unverified" color="bg-signal" textColor="text-brown" />}
      </div>
    </div>

    <p class:list={["mt-3 leading-7", isPast ? "text-muted dark:text-paper/60" : "text-muted dark:text-paper/75"]}>
      {deadline.description}
    </p>
    <p class="mt-2 text-sm text-muted dark:text-paper/65">Applies to: {deadline.appliesTo}</p>

    <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
      {deadline.sourceUrl ? (
        <a href={deadline.sourceUrl} target="_blank" rel="noopener noreferrer" class="brand-text-link font-bold text-teal-deep dark:text-sky">
          {deadline.sourceLabel} ↗
        </a>
      ) : (
        <span class="font-semibold text-signal">Official source not provided</span>
      )}
      <span class="text-xs font-semibold text-muted dark:text-paper/60">
        Checked {formatTorontoDate(deadline.lastVerified)}
      </span>
    </div>

    {isCountdownEligible && status === "upcoming" && (
      <div class="mt-3">
        <Countdown targetDate={deadline.startDate} client:load />
      </div>
    )}
  </div>
</article>
