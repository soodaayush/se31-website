---
import type { Deadline } from "../data/types";
import Badge from "./Badge.astro";
import Countdown from "./Countdown.tsx";
import {
  formatTorontoDate,
  formatTorontoDateTime,
  getDeadlineStatus,
  type DeadlineStatus,
} from "../utils/date";

interface Props {
  deadline: Deadline;
  status?: DeadlineStatus;
}

const { deadline, status: suppliedStatus } = Astro.props;
const status = suppliedStatus ?? getDeadlineStatus(deadline);
const isPast = status === "past";
const isOngoing = status === "ongoing";

const categoryStyleMap: Record<string, { color: string; textColor: string }> = {
  academic: {
    color: "bg-red-100 dark:bg-red-950",
    textColor: "text-red-800 dark:text-red-200",
  },
  "co-op": {
    color: "bg-blue-100 dark:bg-blue-950",
    textColor: "text-blue-800 dark:text-blue-200",
  },
  orientation: {
    color: "bg-green-100 dark:bg-green-950",
    textColor: "text-green-800 dark:text-green-200",
  },
  housing: {
    color: "bg-yellow-100 dark:bg-yellow-950",
    textColor: "text-yellow-900 dark:text-yellow-200",
  },
  financial: {
    color: "bg-purple-100 dark:bg-purple-950",
    textColor: "text-purple-800 dark:text-purple-200",
  },
  residence: {
    color: "bg-indigo-100 dark:bg-indigo-950",
    textColor: "text-indigo-800 dark:text-indigo-200",
  },
  international: {
    color: "bg-pink-100 dark:bg-pink-950",
    textColor: "text-pink-800 dark:text-pink-200",
  },
};

const textColor = isPast ? "text-gray-700 dark:text-gray-300" : "text-gray-900 dark:text-gray-100";
const descriptionColor = isPast ? "text-gray-600 dark:text-gray-400" : "text-gray-700 dark:text-gray-300";
const categoryStyle = isPast
  ? { color: "bg-gray-200 dark:bg-gray-700", textColor: "text-gray-800 dark:text-gray-100" }
  : categoryStyleMap[deadline.category] ?? {
      color: "bg-gray-200 dark:bg-gray-700",
      textColor: "text-gray-800 dark:text-gray-100",
    };

// Check if it's an 'action' type and has a time component (length > 10) for countdown eligibility
const isCountdownEligible = deadline.deadlineType === 'action' && deadline.startDate.length > 10;
---

<article class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-md rounded-xl p-6 flex flex-col">
  <div class="flex justify-between items-start gap-4 mb-2">
    <h3 class={`text-xl font-semibold ${textColor} min-w-0`}>
      {deadline.title}
    </h3>
    <Badge text={deadline.category} color={categoryStyle.color} textColor={categoryStyle.textColor} />
  </div>
  <p class={`text-sm mb-1 font-semibold ${descriptionColor}`}>
    {deadline.deadlineType === 'action' ? 'Action Required' : 'Event'}
  </p>
  <p class={`mb-4 ${descriptionColor}`}>
    {formatTorontoDateTime(deadline.startDate)}
    {deadline.endDate && ` – ${formatTorontoDateTime(deadline.endDate)}`}
  </p>
  <p class={`text-sm mb-4 ${descriptionColor}`}>
    {deadline.description}
  </p>
  <p class="text-xs mb-4 text-gray-600 dark:text-gray-400">Applies to: {deadline.appliesTo}</p>

  <div class="mt-auto">
    <p class="text-sm mb-2">
      {deadline.sourceUrl ? (
        <a href={deadline.sourceUrl} target="_blank" rel="noopener noreferrer" class="font-medium text-blue-700 dark:text-blue-300 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600">
          {deadline.sourceLabel}
        </a>
      ) : (
        <span class="font-medium text-red-700 dark:text-red-300">Official source not provided</span>
      )}
    </p>
    <p class="text-xs text-gray-600 dark:text-gray-400 mb-3">
      Last checked {formatTorontoDate(deadline.lastVerified)}
    </p>
    {isCountdownEligible && status === "upcoming" && (
      <div class="mt-2">
        <Countdown targetDate={deadline.startDate} client:load />
      </div>
    )}
    <div class="mt-3 flex flex-wrap gap-2">
      {isOngoing && (
        <Badge text="Happening now" color="bg-cyan-100 dark:bg-cyan-950" textColor="text-cyan-900 dark:text-cyan-200" />
      )}
      {deadline.priority === "high" && !isPast && (
        <Badge text="High priority" color="bg-amber-100 dark:bg-amber-950" textColor="text-amber-900 dark:text-amber-200" />
      )}
      {deadline.verified ? (
        <Badge text="Source verified" color="bg-green-100 dark:bg-green-950" textColor="text-green-900 dark:text-green-200" />
      ) : (
        <Badge text="Unverified" color="bg-red-100 dark:bg-red-950" textColor="text-red-900 dark:text-red-200" />
      )}
    </div>
  </div>
</article>
