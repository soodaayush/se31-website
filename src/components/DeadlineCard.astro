---
import type { Deadline } from "../data/types";
import Badge from "./Badge.astro";
import Countdown from "./Countdown.tsx";
import { formatTorontoDate } from "../utils/date";

interface Props {
  deadline: Deadline;
  isPast?: boolean;
}

const { deadline, isPast = false } = Astro.props;

const categoryColorMap: { [key: string]: string } = {
  "academic": "bg-red-500",
  "co-op": "bg-blue-500",
  "orientation": "bg-green-500",
  "housing": "bg-yellow-600",
  "financial": "bg-purple-600",
  "residence": "bg-indigo-600",
  "international": "bg-pink-600",
};

const textColor = isPast ? "text-gray-500 dark:text-gray-400" : "text-gray-900 dark:text-gray-100";
const descriptionColor = isPast ? "text-gray-400 dark:text-gray-500" : "text-gray-600 dark:text-gray-300";
const badgeColor = isPast ? "bg-gray-400" : categoryColorMap[deadline.category] || "bg-gray-500";

// Check if it's an 'action' type and has a time component (length > 10) for countdown eligibility
const isCountdownEligible = deadline.deadlineType === 'action' && deadline.startDate.length > 10;
---

<div class={`bg-white dark:bg-gray-800 shadow-lg rounded-lg p-6 ${isPast ? "opacity-70" : ""} flex flex-col`}>
  <div class="flex justify-between items-start mb-2">
    <h3 class={`text-xl font-semibold ${textColor} min-w-0`}>
      {deadline.title}
    </h3>
    <Badge text={deadline.category} color={badgeColor} />
  </div>
  <p class={`text-sm mb-1 font-semibold ${descriptionColor}`}>
    {deadline.deadlineType === 'action' ? 'Action Required' : 'Event'}
  </p>
  <p class={`mb-4 ${descriptionColor}`}>
    {formatTorontoDate(deadline.startDate)}
    {deadline.endDate && ` - ${formatTorontoDate(deadline.endDate)}`}
  </p>
  <p class={`text-sm mb-4 ${descriptionColor}`}>
    {deadline.description}
  </p>
  <p class="text-xs italic mb-4 text-gray-500">Applies to: {deadline.appliesTo}</p>

  <div class="mt-auto">
    {deadline.sourceUrl && (
      <p class="text-sm mb-2">
        <a href={deadline.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-blue-500 hover:underline">
          {deadline.sourceLabel}
        </a>
      </p>
    )}
    {isCountdownEligible && !isPast && (
      <div class="mt-2">
        <Countdown targetDate={deadline.startDate} client:load />
      </div>
    )}
    {deadline.verified && (
      <div class="mt-2">
        <Badge text="Verified" color="bg-green-600" />
      </div>
    )}
  </div>
</div>
