---
import type { Deadline } from "../data/types";
import Badge from "./Badge.astro";
import Countdown from "./Countdown.tsx";
import {
  formatTorontoDate,
  formatTorontoDateTime,
  getDeadlineStatus,
  type DeadlineStatus,
} from "../utils/date";

interface Props {
  deadline: Deadline;
  status?: DeadlineStatus;
}

const { deadline, status: suppliedStatus } = Astro.props;
const status = suppliedStatus ?? getDeadlineStatus(deadline);
const isPast = status === "past";
const isOngoing = status === "ongoing";
const statusBorder = isPast
  ? "border-l-[#48301f]/55"
  : isOngoing
    ? "border-l-[#83ced5]"
    : "border-l-[#f4ad4b]";

const categoryStyleMap: Record<string, { color: string; textColor: string }> = {
  academic: {
    color: "bg-[#f4ad4b]",
    textColor: "text-[#48301f]",
  },
  "co-op": {
    color: "bg-[#83ced5]",
    textColor: "text-[#48301f]",
  },
  orientation: {
    color: "bg-[#f8cb10]",
    textColor: "text-[#48301f]",
  },
  housing: {
    color: "bg-[#fffefb]",
    textColor: "text-[#48301f]",
  },
  financial: {
    color: "bg-[#f4ad4b]",
    textColor: "text-[#48301f]",
  },
  residence: {
    color: "bg-[#83ced5]",
    textColor: "text-[#48301f]",
  },
  international: {
    color: "bg-[#6dacb1]",
    textColor: "text-[#241a14]",
  },
};

const textColor = isPast ? "text-muted dark:text-[#fffefb]/70" : "text-ink dark:text-paper";
const descriptionColor = "text-muted dark:text-[#fffefb]/80";
const categoryStyle = isPast
  ? { color: "bg-[#48301f]", textColor: "text-[#fffefb]" }
  : categoryStyleMap[deadline.category] ?? {
      color: "bg-[#f8cb10]",
      textColor: "text-[#48301f]",
    };

// Check if it's an 'action' type and has a time component (length > 10) for countdown eligibility
const isCountdownEligible = deadline.deadlineType === 'action' && deadline.startDate.length > 10;
---

<article class={`brand-card flex flex-col border-l-[6px] p-6 ${statusBorder}`}>
  <div class="flex justify-between items-start gap-4 mb-2">
    <h3 class={`min-w-0 text-xl font-black tracking-[-0.02em] ${textColor}`}>
      {deadline.title}
    </h3>
    <Badge text={deadline.category} color={categoryStyle.color} textColor={categoryStyle.textColor} />
  </div>
  <p class={`mb-1 text-xs font-black uppercase tracking-[0.08em] ${descriptionColor}`}>
    {deadline.deadlineType === 'action' ? 'Action Required' : 'Event'}
  </p>
  <p class={`mb-4 ${descriptionColor}`}>
    {formatTorontoDateTime(deadline.startDate)}
    {deadline.endDate && ` – ${formatTorontoDateTime(deadline.endDate)}`}
  </p>
  <p class={`text-sm mb-4 ${descriptionColor}`}>
    {deadline.description}
  </p>
  <p class="mb-4 text-xs font-semibold text-muted dark:text-[#fffefb]/70">Applies to: {deadline.appliesTo}</p>

  <div class="mt-auto">
    <p class="mb-2 text-sm">
      {deadline.sourceUrl ? (
        <a href={deadline.sourceUrl} target="_blank" rel="noopener noreferrer" class="brand-text-link font-black text-spruce dark:text-lime">
          {deadline.sourceLabel}
        </a>
      ) : (
        <span class="font-bold text-[#48301f] dark:text-[#f4ad4b]">Official source not provided</span>
      )}
    </p>
    <p class="mb-3 text-[0.7rem] font-bold uppercase tracking-[0.07em] text-muted dark:text-[#fffefb]/70">
      Last checked {formatTorontoDate(deadline.lastVerified)}
    </p>
    {isCountdownEligible && status === "upcoming" && (
      <div class="mt-2">
        <Countdown targetDate={deadline.startDate} client:load />
      </div>
    )}
    <div class="mt-3 flex flex-wrap gap-2">
      {isOngoing && (
        <Badge text="Happening now" color="bg-[#83ced5]" textColor="text-[#48301f]" />
      )}
      {deadline.priority === "high" && !isPast && (
        <Badge text="High priority" color="bg-[#f8cb10]" textColor="text-[#48301f]" />
      )}
      {deadline.verified ? (
        <Badge text="Source verified" color="bg-[#83ced5]" textColor="text-[#48301f]" />
      ) : (
        <Badge text="Unverified" color="bg-[#f4ad4b]" textColor="text-[#48301f]" />
      )}
    </div>
  </div>
</article>
