---
import { SITE_CONFIG } from "../data/siteConfig";
import ThemeToggle from "./ThemeToggle.astro";

const base = import.meta.env.BASE_URL;

const navLinks = [
  { name: "Timetable", href: "timetable" },
  { name: "Deadlines", href: "deadlines" },
  { name: "Announcements", href: "announcements" },
  { name: "Resources", href: "resources" },
  { name: "Projects", href: "projects" },
  { name: "Contribute", href: "contribute" },
];

const normalizePath = (path: string) => path.replace(/\/$/, "");
const currentPath = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-50 bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 shadow-sm">
  <nav class="container mx-auto flex items-center justify-between flex-wrap p-4">
    <div class="flex items-center flex-shrink-0 mr-6">
      <a
        href={base}
        class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white"
      >
        SE31
      </a>
    </div>

    <div class="block lg:hidden">
      <button
        id="nav-toggle"
        class="flex items-center px-3 py-2 border rounded text-gray-700 dark:text-gray-200 border-gray-400 dark:border-gray-500 hover:text-black dark:hover:text-white"
      >
        <svg
          class="fill-current h-3 w-3"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
        >
          <title>Menu</title>
          <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"/>
        </svg>
      </button>
    </div>

    <div
      id="nav-content"
      class="w-full flex-grow lg:flex lg:items-center lg:w-auto hidden"
    >
      <div class="text-sm lg:flex-grow">
        {navLinks.map((link) => (
          <a
            href={`${base}${link.href}`}
            class:list={[
              "relative block mt-4 lg:inline-block lg:mt-0 mr-4 text-gray-700 dark:text-gray-200 hover:text-black dark:hover:text-white after:absolute after:left-0 after:-bottom-1 after:h-0.5 after:w-full after:origin-center after:scale-x-0 after:bg-current after:transition-transform after:duration-200 hover:after:scale-x-100",
              currentPath === normalizePath(`${base}${link.href}`) && "after:scale-x-100",
            ]}
          >
            {link.name}
          </a>
        ))}
      </div>

      <div class="flex items-center gap-2 mt-4 lg:mt-0">
        <ThemeToggle />

        <a
          href={SITE_CONFIG.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors text-gray-900 dark:text-white"
          aria-label="View project on GitHub"
          title="View project on GitHub"
        >
          <svg
            class="h-6 w-6"
            viewBox="0 0 1024 1024"
            fill="currentColor"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              transform="scale(64)"
              d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
            />
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const content = document.getElementById("nav-content");

  toggle?.addEventListener("click", () => {
    content?.classList.toggle("hidden");
  });
</script>
