---
import { SITE_CONFIG } from "../data/siteConfig";
import BrandMark from "./BrandMark.astro";
import ThemeToggle from "./ThemeToggle.astro";

const base = import.meta.env.BASE_URL;

const navLinks = [
  { name: "Courses", href: "courses" },
  { name: "Deadlines", href: "deadlines" },
  { name: "Timetable", href: "timetable", badge: "Unofficial" },
  { name: "Resources", href: "resources" },
  { name: "Contribute", href: "contribute" },
];

const normalizePath = (path: string) => path.replace(/\/$/, "");
const currentPath = normalizePath(Astro.url.pathname);
const isActiveLink = (href: string) => {
  const linkPath = normalizePath(`${base}${href}`);
  return currentPath === linkPath || currentPath.startsWith(`${linkPath}/`);
};
---

<header class="sticky top-0 z-50 border-b border-brown/5 bg-mist/95 shadow-[0_6px_24px_rgb(53_111_114_/_0.06)] backdrop-blur-md dark:border-sky/10 dark:bg-night/95">
  <nav class="mx-auto flex max-w-7xl flex-wrap items-center justify-between px-4 py-3 sm:px-6 lg:px-8" aria-label="Primary navigation">
    <a
      href={base}
      class="group inline-flex items-center gap-3 rounded-xl focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-brown dark:focus-visible:outline-hardhat"
      aria-label="SE31 Nest home"
    >
      <BrandMark class="h-11 w-11" />
      <span class="leading-none">
        <span class="block font-display text-xl font-bold text-ink dark:text-paper">SE31</span>
        <span class="mt-0.5 block text-xs font-semibold text-teal-deep dark:text-sky">the nest</span>
      </span>
    </a>

    <div class="block lg:hidden">
      <button
        id="nav-toggle"
        type="button"
        aria-label="Open navigation menu"
        aria-controls="nav-content"
        aria-expanded="false"
        class="flex min-h-11 min-w-11 items-center justify-center rounded-xl text-ink hover:bg-sky/25 focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-brown dark:text-paper dark:hover:bg-sky/10 dark:focus-visible:outline-hardhat"
      >
        <svg
          class="h-5 w-5 fill-current"
          viewBox="0 0 20 20"
          xmlns="http://www.w3.org/2000/svg"
        >
          <title>Menu</title>
          <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"/>
        </svg>
      </button>
    </div>

    <div
      id="nav-content"
      class="hidden w-full pt-4 lg:flex lg:w-auto lg:flex-grow lg:items-center lg:pt-0"
    >
      <div class="flex flex-col gap-1 border-t border-teal-deep/15 pt-3 lg:ml-8 lg:flex-grow lg:flex-row lg:items-center lg:gap-1 lg:border-0 lg:pt-0 dark:border-sky/15">
        {navLinks.map((link) => (
          <a
            href={`${base}${link.href}`}
            aria-current={isActiveLink(link.href) ? "page" : undefined}
            class:list={[
              "inline-flex min-h-11 items-center gap-2 rounded-xl px-3 py-2 text-sm font-semibold text-ink transition-colors focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-brown dark:focus-visible:outline-hardhat",
              isActiveLink(link.href)
                ? "bg-paper/90 text-ink shadow-[0_4px_14px_rgb(53_111_114_/_0.08)] dark:bg-sky/15 dark:text-paper"
                : "hover:bg-sky/25 dark:text-paper dark:hover:bg-sky/10",
            ]}
          >
            {link.name}
            {link.badge && (
              <span class="inline-flex items-center gap-1 text-[0.64rem] font-bold text-brown dark:text-hardhat">
                <span class="h-1.5 w-1.5 rounded-full bg-signal" aria-hidden="true"></span>{link.badge}
              </span>
            )}
          </a>
        ))}
      </div>

      <div class="mt-3 flex items-center gap-2 lg:mt-0">
        <ThemeToggle />

        <a
          href={SITE_CONFIG.githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-xl text-ink transition-colors hover:bg-sky/25 focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-brown dark:text-paper dark:hover:bg-sky/10 dark:focus-visible:outline-hardhat"
          aria-label="View project on GitHub"
          title="View project on GitHub"
        >
          <svg
            class="h-6 w-6"
            viewBox="0 0 1024 1024"
            fill="currentColor"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              transform="scale(64)"
              d="M8 0C3.58 0 0 3.58 0 8C0 11.54 2.29 14.53 5.47 15.59C5.87 15.66 6.02 15.42 6.02 15.21C6.02 15.02 6.01 14.39 6.01 13.72C4 14.09 3.48 13.23 3.32 12.78C3.23 12.55 2.84 11.84 2.5 11.65C2.22 11.5 1.82 11.13 2.49 11.12C3.12 11.11 3.57 11.7 3.72 11.94C4.44 13.15 5.59 12.81 6.05 12.6C6.12 12.08 6.33 11.73 6.56 11.53C4.78 11.33 2.92 10.64 2.92 7.58C2.92 6.71 3.23 5.99 3.74 5.43C3.66 5.23 3.38 4.41 3.82 3.31C3.82 3.31 4.49 3.1 6.02 4.13C6.66 3.95 7.34 3.86 8.02 3.86C8.7 3.86 9.38 3.95 10.02 4.13C11.55 3.09 12.22 3.31 12.22 3.31C12.66 4.41 12.38 5.23 12.3 5.43C12.81 5.99 13.12 6.7 13.12 7.58C13.12 10.65 11.25 11.33 9.47 11.53C9.76 11.78 10.01 12.26 10.01 13.01C10.01 14.08 10 14.94 10 15.21C10 15.42 10.15 15.67 10.55 15.59C13.71 14.53 16 11.53 16 8C16 3.58 12.42 0 8 0Z"
            />
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const content = document.getElementById("nav-content");

  const setMenuOpen = (isOpen: boolean) => {
    content?.classList.toggle("hidden", !isOpen);
    toggle?.setAttribute("aria-expanded", String(isOpen));
    toggle?.setAttribute("aria-label", isOpen ? "Close navigation menu" : "Open navigation menu");
  };

  toggle?.addEventListener("click", () => {
    setMenuOpen(toggle.getAttribute("aria-expanded") !== "true");
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && toggle?.getAttribute("aria-expanded") === "true") {
      setMenuOpen(false);
      toggle.focus();
    }
  });
</script>
