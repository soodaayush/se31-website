---
import type { Project } from "../data/types";
import Badge from "./Badge.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 shadow-md rounded-xl p-6 flex flex-col">
  <h3 class="text-xl font-semibold text-gray-900 dark:text-gray-100 mb-2">
    {project.name}
  </h3>
  {project.authors && project.authors.length > 0 && (
    <p class="text-sm text-gray-600 dark:text-gray-300 mb-2">
      By: {project.authors.join(", ")}
    </p>
  )}
  <p class="text-gray-600 dark:text-gray-300 mb-4 flex-grow">
    {project.description}
  </p>
  <div class="flex flex-wrap gap-2 mb-4">
    {project.tags.map((tag) => (
      <Badge text={tag} color="bg-purple-100 dark:bg-purple-950" textColor="text-purple-900 dark:text-purple-200" />
    ))}
  </div>
  <div class="flex flex-wrap gap-2 mt-auto">
    {project.repoUrl && (
      <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-11 items-center bg-blue-700 text-white text-sm px-4 py-2 rounded-lg hover:bg-blue-800 transition duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600">
        GitHub Repo
      </a>
    )}
    {project.demoUrl && (
      <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-11 items-center bg-green-700 text-white text-sm px-4 py-2 rounded-lg hover:bg-green-800 transition duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-green-600">
        Live Demo
      </a>
    )}
  </div>
</article>
