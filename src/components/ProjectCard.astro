---
import type { Project } from "../data/types";
import Badge from "./Badge.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="brand-card flex flex-col border-t-[6px] border-t-[#f4ad4b] p-6">
  <h3 class="mb-2 text-xl font-black text-ink dark:text-paper">
    {project.name}
  </h3>
  {project.authors && project.authors.length > 0 && (
    <p class="mb-2 text-sm font-semibold text-muted dark:text-[#fffefb]/70">
      By: {project.authors.join(", ")}
    </p>
  )}
  <p class="mb-4 flex-grow leading-7 text-muted dark:text-[#fffefb]/80">
    {project.description}
  </p>
  <div class="flex flex-wrap gap-2 mb-4">
    {project.tags.map((tag) => (
      <Badge text={tag} color="bg-[#83ced5]" textColor="text-[#48301f]" />
    ))}
  </div>
  <div class="flex flex-wrap gap-2 mt-auto">
    {project.repoUrl && (
      <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="brand-button-primary text-sm">
        GitHub Repo
      </a>
    )}
    {project.demoUrl && (
      <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="brand-button-highlight text-sm">
        Live Demo
      </a>
    )}
  </div>
</article>
