---
import type { Project } from "../data/types";
import Badge from "./Badge.astro";

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<article class="cozy-panel flex flex-col p-6 sm:p-7">
  <h3 class="mb-2 text-xl font-semibold text-ink dark:text-paper">
    {project.name}
  </h3>
  {project.authors && project.authors.length > 0 && (
    <p class="mb-2 text-sm font-semibold text-muted dark:text-paper/65">
      By: {project.authors.join(", ")}
    </p>
  )}
  <p class="mb-4 flex-grow leading-7 text-muted dark:text-paper/75">
    {project.description}
  </p>
  <div class="flex flex-wrap gap-2 mb-4">
    {project.tags.map((tag) => (
      <Badge text={tag} color="bg-sky" textColor="text-brown" />
    ))}
  </div>
  <div class="flex flex-wrap gap-2 mt-auto">
    {project.repoUrl && (
      <a href={project.repoUrl} target="_blank" rel="noopener noreferrer" class="brand-button-primary text-sm">
        GitHub Repo
      </a>
    )}
    {project.demoUrl && (
      <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="brand-button-highlight text-sm">
        Live Demo
      </a>
    )}
  </div>
</article>
