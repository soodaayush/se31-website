---
interface Props {
  class?: string;
}

const { class: className = "h-10 w-10" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<img
  src={`${base}favicon.png`}
  alt=""
  aria-hidden="true"
  class:list={["rounded-[28%] border-2 border-ink object-cover shadow-[2px_2px_0_#48301f]", className]}
  width="1172"
  height="1172"
/>
