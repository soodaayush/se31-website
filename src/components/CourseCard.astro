---
import type { Course } from "../data/types";

interface Props {
  course: Course;
}

const { course } = Astro.props;
const base = import.meta.env.BASE_URL;

const accentClasses: Record<string, { badge: string; border: string }> = {
  "MATH 135": {
    badge: "bg-paper text-brown",
    border: "border-t-paper",
  },
  "MATH 117": {
    badge: "bg-sky text-brown",
    border: "border-t-sky",
  },
  "MATH 115": {
    badge: "bg-signal text-brown",
    border: "border-t-signal",
  },
  "CS 137": {
    badge: "bg-pond-deep text-brown",
    border: "border-t-pond-deep",
  },
  "CHE 102": {
    badge: "bg-hardhat text-brown",
    border: "border-t-hardhat",
  },
  "SE 101": {
    badge: "bg-brown text-paper",
    border: "border-t-brown dark:border-t-paper",
  },
};

const accent = accentClasses[course.code] ?? accentClasses["SE 101"];
---

<article class={`brand-card flex h-full flex-col border-t-4 p-6 transition-transform duration-200 hover:-translate-y-1 motion-reduce:transform-none motion-reduce:transition-none ${accent.border}`}>
  <div class="flex items-start justify-between gap-4 mb-5">
    <span class={`inline-flex rounded-full border-2 border-brown px-3 py-1 text-xs font-black ${accent.badge}`}>
      {course.code}
    </span>
    <span class="text-xs font-bold text-muted dark:text-[#d9d2ca]">
      1A · archived
    </span>
  </div>

  <h2 class="mb-3 text-2xl font-black tracking-[-0.025em] text-ink dark:text-paper">
    {course.title}
  </h2>
  <p class="mb-6 flex-grow leading-7 text-muted dark:text-[#d9d2ca]">
    {course.summary}
  </p>

  <div class="flex flex-col sm:flex-row gap-3 mt-auto">
    <a
      href={`${base}courses/${course.slug}`}
      class="brand-button-primary text-sm"
    >
      Course guide
    </a>
    <a
      href={course.outlineUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="brand-button-secondary text-sm"
    >
      Archived outline ↗
    </a>
  </div>
</article>
