---
import type { Course } from "../data/types";

interface Props {
  course: Course;
}

const { course } = Astro.props;
const base = import.meta.env.BASE_URL;

const department = course.code.split(" ")[0];
const accentClasses: Record<string, { badge: string; border: string; button: string }> = {
  MATH: {
    badge: "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200",
    border: "border-blue-200 dark:border-blue-800",
    button: "bg-blue-600 hover:bg-blue-700 focus-visible:outline-blue-600",
  },
  CS: {
    badge: "bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200",
    border: "border-purple-200 dark:border-purple-800",
    button: "bg-purple-600 hover:bg-purple-700 focus-visible:outline-purple-600",
  },
  CHE: {
    badge: "bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200",
    border: "border-emerald-200 dark:border-emerald-800",
    button: "bg-emerald-600 hover:bg-emerald-700 focus-visible:outline-emerald-600",
  },
  SE: {
    badge: "bg-indigo-100 text-indigo-800 dark:bg-indigo-900 dark:text-indigo-200",
    border: "border-indigo-200 dark:border-indigo-800",
    button: "bg-indigo-600 hover:bg-indigo-700 focus-visible:outline-indigo-600",
  },
};

const accent = accentClasses[department] ?? accentClasses.SE;
---

<article class={`h-full rounded-2xl border ${accent.border} bg-white dark:bg-gray-800 shadow-sm hover:shadow-lg transition-shadow duration-300 p-6 flex flex-col`}>
  <div class="flex items-start justify-between gap-4 mb-5">
    <span class={`inline-flex rounded-full px-3 py-1 text-sm font-bold tracking-wide ${accent.badge}`}>
      {course.code}
    </span>
    <span class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
      1A
    </span>
  </div>

  <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-3">
    {course.title}
  </h2>
  <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-6 flex-grow">
    {course.summary}
  </p>

  <div class="flex flex-col sm:flex-row gap-3 mt-auto">
    <a
      href={`${base}courses/${course.slug}`}
      class={`inline-flex items-center justify-center rounded-lg px-4 py-2.5 text-sm font-semibold text-white transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 ${accent.button}`}
    >
      Course guide
    </a>
    <a
      href={course.outlineUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center rounded-lg border border-gray-300 dark:border-gray-600 px-4 py-2.5 text-sm font-semibold text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600"
    >
      Official outline ↗
    </a>
  </div>
</article>
