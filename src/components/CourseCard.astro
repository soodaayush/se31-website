---
import type { Course } from "../data/types";

interface Props {
  course: Course;
  index?: number;
  total?: number;
}

const { course, index = 0, total = 1 } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<article
  class:list={[
    "flex h-full flex-col border-b border-teal-deep/10 p-6 dark:border-sky/15 sm:p-7",
    index % 2 === 0 ? "md:border-r md:border-teal-deep/10 dark:md:border-sky/15" : "md:border-r-0",
    index >= total - 2 ? "md:border-b-0" : "md:border-b",
  ]}
>
  <p class="font-display text-sm font-semibold text-teal-deep dark:text-sky">{course.code}</p>
  <h2 class="mt-2 text-2xl font-semibold leading-tight text-ink dark:text-paper">
    {course.title}
  </h2>
  <p class="mt-3 flex-grow leading-7 text-muted dark:text-paper/70">
    {course.summary}
  </p>

  <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm">
    <a href={`${base}courses/${course.slug}`} class="brand-text-link font-bold text-teal-deep dark:text-sky">
      Read course guide →
    </a>
    <a href={course.outlineUrl} target="_blank" rel="noopener noreferrer" class="brand-text-link font-semibold text-muted dark:text-paper/70">
      Waterloo outline ↗
    </a>
  </div>
</article>
