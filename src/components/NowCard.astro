---
interface Props {
  label: string;
  title: string;
  href: string;
  linkLabel: string;
  tone?: "lime" | "sky" | "amber";
  external?: boolean;
}

const {
  label,
  title,
  href,
  linkLabel,
  tone = "lime",
  external = false,
} = Astro.props;

const toneClasses = {
  lime: "border-l-hardhat",
  sky: "border-l-sky",
  amber: "border-l-signal",
};
---

<article class={`brand-card flex h-full flex-col border-l-[0.65rem] p-5 sm:p-6 ${toneClasses[tone]}`}>
  <p class="mb-3 text-sm font-extrabold text-brown dark:text-hardhat">
    {label}
  </p>
  <h3 class="text-xl font-extrabold leading-tight tracking-[-0.02em] text-ink dark:text-paper sm:text-2xl">
    {title}
  </h3>
  <div class="mt-4 flex-grow text-sm leading-6 text-muted dark:text-[#d9d2ca]">
    <slot />
  </div>
  <div class="mt-5 border-t-2 border-brown/15 pt-4 dark:border-night-border">
    <slot name="meta" />
    <a
      href={href}
      target={external ? "_blank" : undefined}
      rel={external ? "noopener noreferrer" : undefined}
      class="brand-text-link mt-3 inline-flex items-center gap-1.5 text-sm font-bold text-ink dark:text-paper"
    >
      {linkLabel}<span aria-hidden="true">→</span>
    </a>
  </div>
</article>
