---
---

<button
  id="theme-toggle"
  type="button"
  class="min-h-11 min-w-11 p-2 rounded-lg bg-gray-200 dark:bg-gray-700 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600"
  aria-label="Switch colour theme"
>
  <span id="theme-icon" aria-hidden="true">🌓</span>
</button>

<script is:inline>
  const themeToggle = document.getElementById("theme-toggle");
  const themeIcon = document.getElementById("theme-icon");

  const syncThemeControl = () => {
    const isDark = document.documentElement.classList.contains("dark");
    themeToggle?.setAttribute("aria-label", isDark ? "Switch to light theme" : "Switch to dark theme");
    themeToggle?.setAttribute("title", isDark ? "Switch to light theme" : "Switch to dark theme");
    if (themeIcon) themeIcon.textContent = isDark ? "☀️" : "🌙";
  };

  syncThemeControl();
  requestAnimationFrame(() => document.documentElement.classList.add("theme-transition-ready"));

  themeToggle?.addEventListener("click", () => {
    const isDark = !document.documentElement.classList.contains("dark");
    document.documentElement.classList.toggle("dark", isDark);
    document.documentElement.style.colorScheme = isDark ? "dark" : "light";
    try {
      localStorage.setItem("theme", isDark ? "dark" : "light");
    } catch {
      // The visual control still works when persistent storage is unavailable.
    }
    syncThemeControl();
  });
</script>
