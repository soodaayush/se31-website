---
---

<button
  id="theme-toggle"
  type="button"
  class="inline-flex min-h-11 min-w-11 items-center justify-center rounded-xl text-ink transition-colors hover:bg-sky/25 focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-brown dark:text-paper dark:hover:bg-sky/10 dark:focus-visible:outline-hardhat"
  aria-label="Switch colour theme"
>
  <svg id="theme-icon-moon" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3 6.7 6.7 0 0 0 21 12.8Z" />
  </svg>
  <svg id="theme-icon-sun" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.42 1.42M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.42-1.42M17.66 6.34l1.41-1.41" />
  </svg>
</button>

<script is:inline>
  const themeToggle = document.getElementById("theme-toggle");
  const moonIcon = document.getElementById("theme-icon-moon");
  const sunIcon = document.getElementById("theme-icon-sun");

  const syncThemeControl = () => {
    const isDark = document.documentElement.classList.contains("dark");
    themeToggle?.setAttribute("aria-label", isDark ? "Switch to light theme" : "Switch to dark theme");
    themeToggle?.setAttribute("title", isDark ? "Switch to light theme" : "Switch to dark theme");
    moonIcon?.classList.toggle("hidden", isDark);
    sunIcon?.classList.toggle("hidden", !isDark);
  };

  syncThemeControl();
  requestAnimationFrame(() => document.documentElement.classList.add("theme-transition-ready"));

  themeToggle?.addEventListener("click", () => {
    const isDark = !document.documentElement.classList.contains("dark");
    document.documentElement.classList.toggle("dark", isDark);
    document.documentElement.style.colorScheme = isDark ? "dark" : "light";
    try {
      localStorage.setItem("theme", isDark ? "dark" : "light");
    } catch {
      // The visual control still works when persistent storage is unavailable.
    }
    syncThemeControl();
  });
</script>
