---
import { formatTorontoDate } from "../utils/date";

interface Props {
  announcement: {
    title: string;
    date: string;
    content: string;
  };
}

const { announcement } = Astro.props;
---

<article class="brand-card border-l-[6px] border-l-[#83ced5] p-6">
  <div class="mb-3 flex flex-col items-start justify-between gap-3 sm:flex-row">
    <h2 class="text-2xl font-black text-ink dark:text-paper">{announcement.title}</h2>
    <span class="shrink-0 rounded-full border border-[#48301f]/25 bg-[#f8cb10] px-3 py-1 text-sm font-bold text-[#48301f]">
      {formatTorontoDate(announcement.date)}
    </span>
  </div>

  <p class="whitespace-pre-line leading-7 text-muted dark:text-[#fffefb]/80">
    {announcement.content}
  </p>
</article>
