---
import { formatTorontoDate } from "../utils/date";

interface Props {
  announcement: {
    title: string;
    date: string;
    content: string;
  };
}

const { announcement } = Astro.props;
---

<article class="cozy-panel p-6 sm:p-7">
  <div class="mb-3 flex flex-col items-start justify-between gap-3 sm:flex-row">
    <h2 class="text-2xl font-semibold text-ink dark:text-paper">{announcement.title}</h2>
    <span class="shrink-0 text-sm font-semibold text-teal-deep dark:text-sky">
      {formatTorontoDate(announcement.date)}
    </span>
  </div>

  <p class="whitespace-pre-line leading-7 text-muted dark:text-paper/75">
    {announcement.content}
  </p>
</article>
